// lm_head.ptx -- Dense FP16 matrix-vector multiply for lm_head projection
//
// Computes: output[n] = dot(weight[n, :], input[:])
//   where weight is [248320, 5120] in FP16 row-major
//   and input is [5120] in F32
//
// Params: weight_ptr (u64, FP16), input_ptr (u64, F32), output_ptr (u64, F32)
//
// Launch: grid=(248320/4, 1, 1), block=(128, 1, 1), shared_mem=20736
// Each block: 4 output rows, 128 threads, input cached in shared memory.
// Vectorized loads: ld.global.v4.b16 for weights (4 FP16 per load).
// Each thread processes 5120/128 = 40 elements per row, loading 10 groups of 4.

.version 8.5
.target sm_90
.address_size 64

.visible .entry lm_head(
    .param .u64 weight_ptr,
    .param .u64 input_ptr,
    .param .u64 output_ptr
)
{
    .reg .u64   %rd<30>;
    .reg .u32   %r<50>;
    .reg .f32   %f<30>;
    .reg .pred  %p<10>;
    .reg .b32   %shfl_tmp;
    .reg .b16   %ha, %hb, %hc, %hd;

    // smem: 16 warp sums (4 rows * 4 warps) + 5120 input floats
    // = 64 + 20480 = 20544 bytes
    .shared .align 4 .f32 smem[5136];
    // smem[0..15]     = warp_sums[row * 4 + warp_id]
    // smem[16..5135]  = input[0..5119]

    ld.param.u64    %rd0, [weight_ptr];
    ld.param.u64    %rd1, [input_ptr];
    ld.param.u64    %rd2, [output_ptr];

    // base_row = blockIdx.x * 4
    mov.u32         %r0, %ctaid.x;
    shl.b32         %r0, %r0, 2;

    mov.u32         %r1, %tid.x;
    mov.u32         %r2, 128;            // blockDim
    mov.u32         %r3, 5120;           // hidden_dim

    // Load input into shared memory: 128 threads, 40 elements each
    mov.u32         %r40, smem;
    add.u32         %r41, %r40, 64;      // input_smem = smem + 16*4

    mov.u32         %r5, %r1;
LOAD_INPUT:
    setp.ge.u32     %p0, %r5, %r3;
    @%p0 bra        LOAD_DONE;
    shl.b32         %r6, %r5, 2;
    cvt.u64.u32     %rd3, %r6;
    add.u64         %rd4, %rd1, %rd3;
    ld.global.f32   %f10, [%rd4];
    add.u32         %r7, %r41, %r6;
    st.shared.f32   [%r7], %f10;
    add.u32         %r5, %r5, %r2;
    bra             LOAD_INPUT;
LOAD_DONE:
    bar.sync        0;

    // Weight row bases
    mul.lo.u32      %r10, %r0, 10240;
    cvt.u64.u32     %rd5, %r10;
    add.u64         %rd10, %rd0, %rd5;
    add.u64         %rd11, %rd10, 10240;
    add.u64         %rd12, %rd11, 10240;
    add.u64         %rd13, %rd12, 10240;

    // 4 accumulators
    mov.f32         %f0, 0f00000000;
    mov.f32         %f1, 0f00000000;
    mov.f32         %f2, 0f00000000;
    mov.f32         %f3, 0f00000000;

    // Each thread starts at k = tid * 4, stride = blockDim * 4 = 512
    // This way each thread reads 4 consecutive FP16 values per iteration
    shl.b32         %r5, %r1, 2;         // k = tid * 4
    mov.u32         %r8, 512;            // stride = 128 * 4

K_LOOP:
    setp.ge.u32     %p1, %r5, %r3;
    @%p1 bra        K_DONE;

    // Load 4 input values from shared memory
    shl.b32         %r6, %r5, 2;         // byte offset = k * 4
    add.u32         %r7, %r41, %r6;
    ld.shared.v4.f32 {%f10, %f11, %f12, %f13}, [%r7];

    // Weight byte offset = k * 2
    shl.b32         %r9, %r5, 1;
    cvt.u64.u32     %rd6, %r9;

    // Row 0: load 4 FP16 weights = 8 bytes = v4.b16 via v2.b32
    add.u64         %rd7, %rd10, %rd6;
    ld.global.v2.b32 {%r20, %r21}, [%rd7];
    // Unpack: r20 has [h0, h1], r21 has [h2, h3]
    // Extract low/high halves
    mov.b32         {%ha, %hb}, %r20;
    cvt.f32.f16     %f20, %ha;
    fma.rn.f32      %f0, %f20, %f10, %f0;
    cvt.f32.f16     %f20, %hb;
    fma.rn.f32      %f0, %f20, %f11, %f0;
    mov.b32         {%ha, %hb}, %r21;
    cvt.f32.f16     %f20, %ha;
    fma.rn.f32      %f0, %f20, %f12, %f0;
    cvt.f32.f16     %f20, %hb;
    fma.rn.f32      %f0, %f20, %f13, %f0;

    // Row 1
    add.u64         %rd7, %rd11, %rd6;
    ld.global.v2.b32 {%r20, %r21}, [%rd7];
    mov.b32         {%ha, %hb}, %r20;
    cvt.f32.f16     %f20, %ha;
    fma.rn.f32      %f1, %f20, %f10, %f1;
    cvt.f32.f16     %f20, %hb;
    fma.rn.f32      %f1, %f20, %f11, %f1;
    mov.b32         {%ha, %hb}, %r21;
    cvt.f32.f16     %f20, %ha;
    fma.rn.f32      %f1, %f20, %f12, %f1;
    cvt.f32.f16     %f20, %hb;
    fma.rn.f32      %f1, %f20, %f13, %f1;

    // Row 2
    add.u64         %rd7, %rd12, %rd6;
    ld.global.v2.b32 {%r20, %r21}, [%rd7];
    mov.b32         {%ha, %hb}, %r20;
    cvt.f32.f16     %f20, %ha;
    fma.rn.f32      %f2, %f20, %f10, %f2;
    cvt.f32.f16     %f20, %hb;
    fma.rn.f32      %f2, %f20, %f11, %f2;
    mov.b32         {%ha, %hb}, %r21;
    cvt.f32.f16     %f20, %ha;
    fma.rn.f32      %f2, %f20, %f12, %f2;
    cvt.f32.f16     %f20, %hb;
    fma.rn.f32      %f2, %f20, %f13, %f2;

    // Row 3
    add.u64         %rd7, %rd13, %rd6;
    ld.global.v2.b32 {%r20, %r21}, [%rd7];
    mov.b32         {%ha, %hb}, %r20;
    cvt.f32.f16     %f20, %ha;
    fma.rn.f32      %f3, %f20, %f10, %f3;
    cvt.f32.f16     %f20, %hb;
    fma.rn.f32      %f3, %f20, %f11, %f3;
    mov.b32         {%ha, %hb}, %r21;
    cvt.f32.f16     %f20, %ha;
    fma.rn.f32      %f3, %f20, %f12, %f3;
    cvt.f32.f16     %f20, %hb;
    fma.rn.f32      %f3, %f20, %f13, %f3;

    add.u32         %r5, %r5, %r8;
    bra             K_LOOP;

K_DONE:
    // Warp shuffle reduction -- 4 accumulators
    // Row 0
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;

    // Row 1
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;

    // Row 2
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;

    // Row 3
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;

    // Lane 0 of each warp stores 4 sums
    shr.b32         %r30, %r1, 5;
    and.b32         %r31, %r1, 31;
    setp.eq.u32     %p2, %r31, 0;

    mov.u32         %r40, smem;
    shl.b32         %r32, %r30, 2;       // warp_id * 4 bytes

    // Row 0: smem[warp_id]
    add.u32         %r33, %r40, %r32;
    @%p2 st.shared.f32 [%r33], %f0;
    // Row 1: smem[4 + warp_id]
    add.u32         %r34, %r33, 16;
    @%p2 st.shared.f32 [%r34], %f1;
    // Row 2: smem[8 + warp_id]
    add.u32         %r35, %r34, 16;
    @%p2 st.shared.f32 [%r35], %f2;
    // Row 3: smem[12 + warp_id]
    add.u32         %r36, %r35, 16;
    @%p2 st.shared.f32 [%r36], %f3;

    bar.sync        0;

    // Threads 0-3 each sum one row across 4 warps
    setp.ge.u32     %p3, %r1, 4;
    @%p3 bra        DONE;

    // smem offset for row r1: smem + r1 * 4 * 4 = smem + r1 * 16
    shl.b32         %r42, %r1, 4;
    mov.u32         %r40, smem;
    add.u32         %r43, %r40, %r42;

    ld.shared.f32   %f25, [%r43];
    ld.shared.f32   %f26, [%r43+4];
    add.f32         %f25, %f25, %f26;
    ld.shared.f32   %f26, [%r43+8];
    add.f32         %f25, %f25, %f26;
    ld.shared.f32   %f26, [%r43+12];
    add.f32         %f25, %f25, %f26;

    // Store output[base_row + r1]
    add.u32         %r47, %r0, %r1;
    cvt.u64.u32     %rd20, %r47;
    shl.b64         %rd20, %rd20, 2;
    add.u64         %rd21, %rd2, %rd20;
    st.global.f32   [%rd21], %f25;

DONE:
    ret;
}
