.version 8.0
.target sm_90
.address_size 64

.visible .entry probe_mufu(
    .param .u64 param_out
)
{
    .reg .f32 %f<20>;
    .reg .u64 %rd<4>;

    ld.param.u64 %rd0, [param_out];

    mov.f32 %f0, 0f3F800000;  // 1.0
    mov.f32 %f1, 0f40000000;  // 2.0

    // RCP (reciprocal)
    rcp.approx.f32 %f2, %f0;

    // RSQRT
    rsqrt.approx.f32 %f3, %f1;

    // EX2 (2^x)
    ex2.approx.f32 %f4, %f0;

    // LG2 (log2)
    lg2.approx.f32 %f5, %f1;

    // SIN
    sin.approx.f32 %f6, %f0;

    // COS
    cos.approx.f32 %f7, %f1;

    // Store all
    st.global.f32 [%rd0], %f2;
    st.global.f32 [%rd0+4], %f3;
    st.global.f32 [%rd0+8], %f4;
    st.global.f32 [%rd0+12], %f5;
    st.global.f32 [%rd0+16], %f6;
    st.global.f32 [%rd0+20], %f7;

    ret;
}
