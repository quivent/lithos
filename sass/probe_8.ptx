.version 8.0
.target sm_90
.address_size 64

.visible .entry probe_async_copy(
    .param .u64 param_in
)
{
    .reg .u64 %rd<4>;
    .reg .u32 %r<4>;

    .shared .align 16 .b8 smem[256];

    ld.param.u64 %rd0, [param_in];

    // CP.ASYNC - async copy from global to shared
    cp.async.ca.shared.global [smem], [%rd0], 16;
    cp.async.ca.shared.global [smem+16], [%rd0+16], 16;

    // CP.ASYNC commit group
    cp.async.commit_group;

    // CP.ASYNC wait group
    cp.async.wait_group 0;

    bar.sync 0;

    // Load from shared to verify
    ld.shared.b32 %r0, [smem];
    st.global.b32 [%rd0], %r0;

    ret;
}
