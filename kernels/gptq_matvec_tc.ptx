    mov.b32 %shfl, %f4;
    shfl.sync.down.b32 %shfl, %shfl, 4, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f4, %f4, %f10;
    mov.b32 %shfl, %f4;
    shfl.sync.down.b32 %shfl, %shfl, 2, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f4, %f4, %f10;
    mov.b32 %shfl, %f4;
    shfl.sync.down.b32 %shfl, %shfl, 1, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f4, %f4, %f10;

    // f5
    mov.b32 %shfl, %f5;
    shfl.sync.down.b32 %shfl, %shfl, 16, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f5, %f5, %f10;
    mov.b32 %shfl, %f5;
    shfl.sync.down.b32 %shfl, %shfl, 8, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f5, %f5, %f10;
    mov.b32 %shfl, %f5;
    shfl.sync.down.b32 %shfl, %shfl, 4, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f5, %f5, %f10;
    mov.b32 %shfl, %f5;
    shfl.sync.down.b32 %shfl, %shfl, 2, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f5, %f5, %f10;
    mov.b32 %shfl, %f5;
    shfl.sync.down.b32 %shfl, %shfl, 1, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f5, %f5, %f10;

    // f6
    mov.b32 %shfl, %f6;
    shfl.sync.down.b32 %shfl, %shfl, 16, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f6, %f6, %f10;
    mov.b32 %shfl, %f6;
