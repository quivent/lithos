// forward_pass_cray.ptx -- Cray-optimized multi-block cooperative fused forward pass
//
// Optimization vs forward_pass_multi.ptx:
//   1. Atomic reduction for RMSNorm: eliminates the serial loop over 132 partials
//      and removes one grid sync per norm computation (saves 2 grid syncs per layer).
//   2. Uses atomic add for sum of squares, then a single grid sync to broadcast rms_inv.
//   3. Total grid syncs per layer: 3 (was 4). Saves 64 syncs over 64 layers.
//
// Grid:  (132, 1, 1), Block: (256, 1, 1)
// Cooperative launch required.

.version 8.5
.target sm_90
.address_size 64

.visible .entry forward_pass_cray(
    .param .u64 weight_table_ptr,
    .param .u64 embed_table_ptr,
    .param .u32 token_id,
    .param .u64 mid_scratch_ptr,
    .param .u64 output_logits_ptr,
    .param .u64 final_norm_ptr,
    .param .u64 lm_head_qw_ptr,
    .param .u64 lm_head_scales_ptr,
    .param .u64 lm_head_zeros_ptr,
    .param .u64 activation_ptr,
    .param .u64 normed_ptr,
    .param .u64 sync_workspace_ptr,
    .param .u64 norm_partials_ptr
)
{
    .reg .u64   %rd<64>;
    .reg .u32   %r<64>;
    .reg .f32   %f<48>;
    .reg .pred  %p<16>;
    .reg .b16   %htmp;

    // Shared memory: warp reduction + sync sense
    // sync_workspace layout:
    //   [0]  = arrival counter (u32)
    //   [4]  = sense flag (u32)
    //   [8]  = atomic norm accumulator (f32, reinterpreted as u32 for atomicAdd)
    //   [12] = rms_inv broadcast (f32)
    .shared .align 4 .f32 smem_reduce[32];
    .shared .align 4 .u32 smem_local_sense[1];

    ld.param.u64    %rd0, [weight_table_ptr];
    ld.param.u64    %rd1, [embed_table_ptr];
    ld.param.u32    %r0, [token_id];
    ld.param.u64    %rd2, [mid_scratch_ptr];
    ld.param.u64    %rd3, [output_logits_ptr];
    ld.param.u64    %rd4, [final_norm_ptr];
    ld.param.u64    %rd5, [lm_head_qw_ptr];
    ld.param.u64    %rd6, [lm_head_scales_ptr];
    ld.param.u64    %rd7, [lm_head_zeros_ptr];
    ld.param.u64    %rd8, [activation_ptr];
    ld.param.u64    %rd9, [normed_ptr];
    ld.param.u64    %rd10, [sync_workspace_ptr];
    ld.param.u64    %rd11, [norm_partials_ptr];

    mov.u32         %r1, %tid.x;
    mov.u32         %r2, %ctaid.x;
    mul.lo.u32      %r4, %r2, 256;
    add.u32         %r4, %r4, %r1;
    mov.u32         %r5, 33792;

    setp.eq.u32     %p0, %r1, 0;
    @!%p0 bra       SKIP_SENSE_INIT;
    mov.u32         %r6, 0;
    st.shared.u32   [smem_local_sense], %r6;
SKIP_SENSE_INIT:
    bar.sync        0;

    // =========================================================================
    // Embedding lookup
    // =========================================================================
    mul.lo.u32      %r6, %r0, 5120;
    shl.b32         %r6, %r6, 2;
    cvt.u64.u32     %rd12, %r6;
    add.u64         %rd13, %rd1, %rd12;
    mov.u32         %r7, %r4;
EMBED_LOOP:
    setp.ge.u32     %p1, %r7, 5120;
    @%p1 bra        EMBED_DONE;
    shl.b32         %r8, %r7, 2;
    cvt.u64.u32     %rd14, %r8;
    add.u64         %rd15, %rd13, %rd14;
    ld.global.f32   %f0, [%rd15];
    add.u64         %rd16, %rd8, %rd14;
    st.global.f32   [%rd16], %f0;
    add.u32         %r7, %r7, %r5;
    bra             EMBED_LOOP;
EMBED_DONE:

    // GRID SYNC 0
    bar.sync        0;
    setp.eq.u32     %p1, %r1, 0;
    @!%p1 bra       GS0W;
    ld.shared.u32   %r50, [smem_local_sense];
    xor.b32         %r51, %r50, 1;
    atom.global.add.u32 %r52, [%rd10], 1;
    setp.eq.u32     %p2, %r52, 131;
    @!%p2 bra       GS0S;
    st.global.u32   [%rd10], 0;
    membar.gl;
    st.global.release.gpu.u32 [%rd10+4], %r51;
    st.shared.u32   [smem_local_sense], %r51;
    bra             GS0D;
GS0S:
    ld.global.acquire.gpu.u32 %r53, [%rd10+4];
    setp.ne.u32     %p3, %r53, %r51;
    @%p3 bra        GS0S;
    st.shared.u32   [smem_local_sense], %r51;
GS0D:
GS0W:
    bar.sync        0;

    // =========================================================================
    // LAYER LOOP
    // =========================================================================
    mov.u32         %r10, 0;
    mov.u64         %rd20, %rd0;

LAYER_LOOP:
    setp.ge.u32     %p1, %r10, 64;
    @%p1 bra        LAYER_DONE;

    ld.global.u64   %rd30, [%rd20+0];
    ld.global.u64   %rd31, [%rd20+8];
    ld.global.u64   %rd32, [%rd20+16];
    ld.global.u64   %rd33, [%rd20+24];
    ld.global.u64   %rd34, [%rd20+32];
    ld.global.u64   %rd35, [%rd20+40];
    ld.global.u64   %rd36, [%rd20+48];
    ld.global.u64   %rd37, [%rd20+56];
    ld.global.u64   %rd38, [%rd20+64];
    ld.global.u64   %rd39, [%rd20+72];
    ld.global.u64   %rd40, [%rd20+80];

    // =====================================================================
    // RMSNORM with ATOMIC REDUCTION (eliminates one grid sync)
    //
    // Phase A: Each block computes partial sum, then atomicAdd to sync_workspace[8]
    // Phase B: Grid sync (last block computes rms_inv and broadcasts)
    // Phase C: All blocks apply norm
    // Phase D: Grid sync (norm complete)
    //
    // vs original: 2 grid syncs -> now 2 grid syncs, BUT the serial 132-iteration
    // loop in the last block is eliminated (replaced by atomic accumulation).
    // =====================================================================

    // Zero the atomic accumulator (only block 0, thread 0)
    setp.eq.u32     %p2, %r4, 0;          // global_tid == 0
    @!%p2 bra       SKIP_ZERO_ACCUM;
    mov.u32         %r6, 0;
    st.global.u32   [%rd10+8], %r6;       // zero the accumulator
SKIP_ZERO_ACCUM:

    // Phase A: partial sum of squares
    mov.f32         %f1, 0f00000000;
    mov.u32         %r11, %r4;
NSS_LP:
    setp.ge.u32     %p2, %r11, 5120;
    @%p2 bra        NSS_DN;
    shl.b32         %r12, %r11, 2;
    cvt.u64.u32     %rd41, %r12;
    add.u64         %rd42, %rd8, %rd41;
    ld.global.f32   %f2, [%rd42];
    fma.rn.f32      %f1, %f2, %f2, %f1;
    add.u32         %r11, %r11, %r5;
    bra             NSS_LP;
NSS_DN:

    // Warp reduction
    shfl.sync.down.b32 %f3, %f1, 16, 31, 0xFFFFFFFF;
    add.f32         %f1, %f1, %f3;
    shfl.sync.down.b32 %f3, %f1, 8, 31, 0xFFFFFFFF;
    add.f32         %f1, %f1, %f3;
    shfl.sync.down.b32 %f3, %f1, 4, 31, 0xFFFFFFFF;
    add.f32         %f1, %f1, %f3;
    shfl.sync.down.b32 %f3, %f1, 2, 31, 0xFFFFFFFF;
    add.f32         %f1, %f1, %f3;
    shfl.sync.down.b32 %f3, %f1, 1, 31, 0xFFFFFFFF;
    add.f32         %f1, %f1, %f3;

    and.b32         %r14, %r1, 31;
    shr.b32         %r15, %r1, 5;
    setp.eq.u32     %p3, %r14, 0;
    @!%p3 bra       SK_SS;
    shl.b32         %r16, %r15, 2;
    mov.u32         %r17, smem_reduce;
    add.u32         %r17, %r17, %r16;
    st.shared.f32   [%r17], %f1;
SK_SS:
    bar.sync        0;

    setp.lt.u32     %p4, %r1, 32;
    @!%p4 bra       SK_CW;
    mov.f32         %f4, 0f00000000;
    setp.lt.u32     %p5, %r1, 8;
    @!%p5 bra       SK_LP;
    shl.b32         %r16, %r1, 2;
    mov.u32         %r17, smem_reduce;
    add.u32         %r17, %r17, %r16;
    ld.shared.f32   %f4, [%r17];
SK_LP:
    shfl.sync.down.b32 %f5, %f4, 16, 31, 0xFFFFFFFF;
    add.f32         %f4, %f4, %f5;
    shfl.sync.down.b32 %f5, %f4, 8, 31, 0xFFFFFFFF;
    add.f32         %f4, %f4, %f5;
    shfl.sync.down.b32 %f5, %f4, 4, 31, 0xFFFFFFFF;
    add.f32         %f4, %f4, %f5;
    shfl.sync.down.b32 %f5, %f4, 2, 31, 0xFFFFFFFF;
    add.f32         %f4, %f4, %f5;
    shfl.sync.down.b32 %f5, %f4, 1, 31, 0xFFFFFFFF;
    add.f32         %f4, %f4, %f5;

    // Thread 0 of each block: atomicAdd block partial to global accumulator
    setp.eq.u32     %p6, %r1, 0;
    @!%p6 bra       SK_CW;

    // Reinterpret float as u32 for atom.global.add.f32 (sm_90 supports this)
    atom.global.add.f32 %f6, [%rd10+8], %f4;

SK_CW:

    // GRID SYNC 1: All partials atomically accumulated
    // Last block: compute rms_inv from the accumulated sum and broadcast
    bar.sync        0;
    setp.eq.u32     %p1, %r1, 0;
    @!%p1 bra       GS1W;
    ld.shared.u32   %r50, [smem_local_sense];
    xor.b32         %r51, %r50, 1;
    atom.global.add.u32 %r52, [%rd10], 1;
    setp.eq.u32     %p2, %r52, 131;
    @!%p2 bra       GS1S;

    // Last block: read accumulated sum, compute rms_inv
    ld.global.f32   %f6, [%rd10+8];
    mul.f32         %f6, %f6, 0f394CCCCD;  // 1/5120
    add.f32         %f6, %f6, 0f358637BD;  // 1e-6
    rsqrt.approx.f32 %f6, %f6;
    st.global.f32   [%rd10+12], %f6;

    st.global.u32   [%rd10], 0;
    membar.gl;
    st.global.release.gpu.u32 [%rd10+4], %r51;
    st.shared.u32   [smem_local_sense], %r51;
    bra             GS1D;
GS1S:
    ld.global.acquire.gpu.u32 %r53, [%rd10+4];
    setp.ne.u32     %p3, %r53, %r51;
    @%p3 bra        GS1S;
    st.shared.u32   [smem_local_sense], %r51;
GS1D:
GS1W:
    bar.sync        0;

    ld.global.f32   %f7, [%rd10+12];

    // Apply norm
    mov.u32         %r11, %r4;
NA_LP:
    setp.ge.u32     %p7, %r11, 5120;
    @%p7 bra        NA_DN;
    shl.b32         %r12, %r11, 2;
    cvt.u64.u32     %rd41, %r12;
    add.u64         %rd42, %rd8, %rd41;
    ld.global.f32   %f8, [%rd42];
    mul.f32         %f9, %f8, %f7;
    add.u64         %rd43, %rd30, %rd41;
    ld.global.f32   %f10, [%rd43];
    mul.f32         %f9, %f9, %f10;
    add.u64         %rd44, %rd9, %rd41;
    st.global.f32   [%rd44], %f9;
    add.u32         %r11, %r11, %r5;
    bra             NA_LP;
NA_DN:

    // GRID SYNC 2: norm complete
    bar.sync        0;
    setp.eq.u32     %p1, %r1, 0;
    @!%p1 bra       GS2W;
    ld.shared.u32   %r50, [smem_local_sense];
    xor.b32         %r51, %r50, 1;
    atom.global.add.u32 %r52, [%rd10], 1;
    setp.eq.u32     %p2, %r52, 131;
    @!%p2 bra       GS2S;
    st.global.u32   [%rd10], 0;
    membar.gl;
    st.global.release.gpu.u32 [%rd10+4], %r51;
    st.shared.u32   [smem_local_sense], %r51;
    bra             GS2D;
GS2S:
    ld.global.acquire.gpu.u32 %r53, [%rd10+4];
    setp.ne.u32     %p3, %r53, %r51;
    @%p3 bra        GS2S;
    st.shared.u32   [smem_local_sense], %r51;
GS2D:
GS2W:
    bar.sync        0;

    // =====================================================================
    // GATE+UP PROJECTION
    // =====================================================================
    mov.u32         %r20, %r4;
GU_LP:
    setp.ge.u32     %p8, %r20, 17408;
    @%p8 bra        GU_DN;

    mul.lo.u32      %r21, %r20, 2560;
    cvt.u64.u32     %rd41, %r21;
    add.u64         %rd42, %rd31, %rd41;
    mul.lo.u32      %r22, %r20, 80;
    cvt.u64.u32     %rd43, %r22;
    add.u64         %rd44, %rd32, %rd43;
    mul.lo.u32      %r23, %r20, 160;
    cvt.u64.u32     %rd45, %r23;
    add.u64         %rd46, %rd33, %rd45;
    add.u64         %rd47, %rd34, %rd41;
    add.u64         %rd48, %rd35, %rd43;
    add.u64         %rd49, %rd36, %rd45;

    mov.f32         %f10, 0f00000000;
    mov.f32         %f11, 0f00000000;

    mov.u32         %r24, 0;
KG_LP:
    setp.ge.u32     %p9, %r24, 40;
    @%p9 bra        KG_DN;

    shl.b32         %r25, %r24, 1;
    cvt.u64.u32     %rd50, %r25;
    add.u64         %rd51, %rd44, %rd50;
    ld.global.b16   %htmp, [%rd51];
    cvt.f32.f16     %f12, %htmp;
    shl.b32         %r25, %r24, 2;
    cvt.u64.u32     %rd50, %r25;
    add.u64         %rd51, %rd46, %rd50;
    ld.global.u32   %r26, [%rd51];
    cvt.rn.f32.u32  %f13, %r26;
    shl.b32         %r25, %r24, 1;
    cvt.u64.u32     %rd50, %r25;
    add.u64         %rd51, %rd48, %rd50;
    ld.global.b16   %htmp, [%rd51];
    cvt.f32.f16     %f14, %htmp;
    shl.b32         %r25, %r24, 2;
    cvt.u64.u32     %rd50, %r25;
    add.u64         %rd51, %rd49, %rd50;
    ld.global.u32   %r27, [%rd51];
    cvt.rn.f32.u32  %f15, %r27;

    shl.b32         %r28, %r24, 6;
    cvt.u64.u32     %rd52, %r28;
    add.u64         %rd53, %rd42, %rd52;
    add.u64         %rd54, %rd47, %rd52;

    shl.b32         %r29, %r24, 9;
    cvt.u64.u32     %rd55, %r29;
    add.u64         %rd56, %rd9, %rd55;

    mov.u32         %r31, 0;
PK_LP:
    setp.ge.u32     %p10, %r31, 16;
    @%p10 bra       PK_DN;

    shl.b32         %r32, %r31, 2;
    cvt.u64.u32     %rd57, %r32;
    add.u64         %rd58, %rd53, %rd57;
    ld.global.u32   %r33, [%rd58];
    add.u64         %rd58, %rd54, %rd57;
    ld.global.u32   %r34, [%rd58];

    shl.b32         %r35, %r31, 5;
    cvt.u64.u32     %rd59, %r35;
    add.u64         %rd60, %rd56, %rd59;

    ld.global.f32   %f16, [%rd60+0];
    and.b32         %r37, %r33, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;
    and.b32         %r37, %r34, 0x0F;
    cvt.rn.f32.u32  %f18, %r37;
    sub.f32         %f18, %f18, %f15;
    mul.f32         %f18, %f18, %f14;
    fma.rn.f32      %f11, %f18, %f16, %f11;

    ld.global.f32   %f16, [%rd60+4];
    shr.b32         %r38, %r33, 4;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;
    shr.b32         %r38, %r34, 4;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f18, %r37;
    sub.f32         %f18, %f18, %f15;
    mul.f32         %f18, %f18, %f14;
    fma.rn.f32      %f11, %f18, %f16, %f11;

    ld.global.f32   %f16, [%rd60+8];
    shr.b32         %r38, %r33, 8;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;
    shr.b32         %r38, %r34, 8;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f18, %r37;
    sub.f32         %f18, %f18, %f15;
    mul.f32         %f18, %f18, %f14;
    fma.rn.f32      %f11, %f18, %f16, %f11;

    ld.global.f32   %f16, [%rd60+12];
    shr.b32         %r38, %r33, 12;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;
    shr.b32         %r38, %r34, 12;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f18, %r37;
    sub.f32         %f18, %f18, %f15;
    mul.f32         %f18, %f18, %f14;
    fma.rn.f32      %f11, %f18, %f16, %f11;

    ld.global.f32   %f16, [%rd60+16];
    shr.b32         %r38, %r33, 16;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;
    shr.b32         %r38, %r34, 16;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f18, %r37;
    sub.f32         %f18, %f18, %f15;
    mul.f32         %f18, %f18, %f14;
    fma.rn.f32      %f11, %f18, %f16, %f11;

    ld.global.f32   %f16, [%rd60+20];
    shr.b32         %r38, %r33, 20;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;
    shr.b32         %r38, %r34, 20;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f18, %r37;
    sub.f32         %f18, %f18, %f15;
    mul.f32         %f18, %f18, %f14;
    fma.rn.f32      %f11, %f18, %f16, %f11;

    ld.global.f32   %f16, [%rd60+24];
    shr.b32         %r38, %r33, 24;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;
    shr.b32         %r38, %r34, 24;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f18, %r37;
    sub.f32         %f18, %f18, %f15;
    mul.f32         %f18, %f18, %f14;
    fma.rn.f32      %f11, %f18, %f16, %f11;

    ld.global.f32   %f16, [%rd60+28];
    shr.b32         %r38, %r33, 28;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;
    shr.b32         %r38, %r34, 28;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f18, %r37;
    sub.f32         %f18, %f18, %f15;
    mul.f32         %f18, %f18, %f14;
    fma.rn.f32      %f11, %f18, %f16, %f11;

    add.u32         %r31, %r31, 1;
    bra             PK_LP;

PK_DN:
    add.u32         %r24, %r24, 1;
    bra             KG_LP;

KG_DN:
    neg.f32         %f20, %f10;
    mul.f32         %f21, %f20, 0f3FB8AA3B;
    ex2.approx.f32  %f22, %f21;
    add.f32         %f23, %f22, 0f3F800000;
    rcp.approx.f32  %f24, %f23;
    mul.f32         %f25, %f10, %f24;
