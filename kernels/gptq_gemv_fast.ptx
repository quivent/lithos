// gptq_gemv_fast.ptx -- Bandwidth-optimized GPTQ W4A16 GEMV
//
// K-split coalesced GEMV with shared memory + FMA dequant:
// - 256 output cols/block, 1 thread per col -> perfect coalescing
// - K split across grid.y for parallelism
// - Input slice in shared memory
// - dequant(nib) = nib * scale + bias (bias = -8 * scale, precomputed)
// - 2x loop unroll, pointer arithmetic (no multiply in hot loop)
//
// Launch: grid=(ceil(N/256), K_SPLITS, 1), block=(256, 1, 1)
//   smem = k_packed_per_split * 32 bytes

.version 8.5
.target sm_90
.address_size 64

.extern .shared .align 16 .b8 smem_base[];

.visible .entry gptq_gemv_fast(
    .param .u64 qweight_ptr,
    .param .u64 scales_ptr,
    .param .u64 input_ptr,
    .param .u64 output_ptr,
    .param .u32 param_N,
    .param .u32 param_K,
    .param .u32 param_K_SPLITS,
    .param .u32 param_k_packed_per_split
)
{
    .reg .u64   %rd<40>;
    .reg .u32   %r<70>;
    .reg .f32   %f<20>;
    .reg .pred  %p<16>;
    .reg .b16   %htmp;
    .reg .u32   %nib;
    .reg .f32   %dq, %scale, %bias, %acc;
    .reg .u32   %packed;
    .reg .f32   %x0, %x1, %x2, %x3, %x4, %x5, %x6, %x7;

    ld.param.u64    %rd0, [qweight_ptr];
    ld.param.u64    %rd1, [scales_ptr];
    ld.param.u64    %rd2, [input_ptr];
    ld.param.u64    %rd3, [output_ptr];
    ld.param.u32    %r0,  [param_N];
    ld.param.u32    %r1,  [param_K];
    ld.param.u32    %r2,  [param_K_SPLITS];
    ld.param.u32    %r8,  [param_k_packed_per_split];

    mov.u32         %r3,  %tid.x;
    mov.u32         %r4,  %ctaid.x;
    mov.u32         %r5,  %ctaid.y;

    shl.b32         %r10, %r4, 8;
    add.u32         %r11, %r10, %r3;

    setp.ge.u32     %p0, %r11, %r0;
    @%p0 bra        DONE;

    shr.b32         %r30, %r1, 3;
    mul.lo.u32      %r32, %r5, %r8;
    add.u32         %r33, %r32, %r8;
    min.u32         %r33, %r33, %r30;
    min.u32         %r32, %r32, %r30;
    sub.u32         %r34, %r33, %r32;
    setp.eq.u32     %p1, %r34, 0;
    @%p1 bra        DONE;

    // Load input slice into shared memory
    mov.u32         %r20, smem_base;
    shl.b32         %r35, %r34, 3;
    shl.b32         %r36, %r32, 3;

    mov.u32         %r37, %r3;
LOAD_X:
    setp.ge.u32     %p2, %r37, %r35;
    @%p2 bra        LOAD_X_DONE;
    add.u32         %r38, %r37, %r36;
    cvt.u64.u32     %rd10, %r38;
    shl.b64         %rd11, %rd10, 2;
    add.u64         %rd12, %rd2, %rd11;
    ld.global.ca.f32 %f0, [%rd12];
    shl.b32         %r39, %r37, 2;
    add.u32         %r40, %r20, %r39;
    st.shared.f32   [%r40], %f0;
    add.u32         %r37, %r37, 256;
    bra             LOAD_X;
LOAD_X_DONE:
    bar.sync        0;

    // Setup
    shl.b32         %r41, %r0, 2;
    cvt.u64.u32     %rd20, %r41;
    shl.b32         %r42, %r0, 1;
    cvt.u64.u32     %rd21, %r42;

    shl.b32         %r43, %r11, 2;
    cvt.u64.u32     %rd22, %r43;
    shl.b32         %r44, %r11, 1;
    cvt.u64.u32     %rd23, %r44;

    cvt.u64.u32     %rd26, %r32;
    mul.lo.u64      %rd27, %rd26, %rd20;
    add.u64         %rd28, %rd0, %rd27;
    add.u64         %rd28, %rd28, %rd22;
    add.u64         %rd25, %rd1, %rd23;

    mov.f32         %acc, 0f00000000;
    mov.u32         %r45, 0xFFFFFFFF;
    mov.f32         %scale, 0f00000000;
    mov.f32         %bias, 0f00000000;

    mov.u32         %r50, %r32;
    mov.u32         %r51, 0;

    shr.b32         %r60, %r34, 1;
    mov.u32         %r61, 0;

K_LOOP_PAIR:
    setp.ge.u32     %p3, %r61, %r60;
    @%p3 bra        K_LOOP_PAIR_DONE;

    // --- Iteration A ---
    shr.b32         %r53, %r50, 4;
    setp.eq.u32     %p4, %r53, %r45;
    @%p4 bra        SKIP_SCALE_A;
    mov.u32         %r45, %r53;
    cvt.u64.u32     %rd29, %r53;
    mul.lo.u64      %rd30, %rd29, %rd21;
    add.u64         %rd31, %rd25, %rd30;
    ld.global.ca.b16 %htmp, [%rd31];
    cvt.f32.f16     %scale, %htmp;
    mul.f32         %bias, %scale, 0fC1000000;
SKIP_SCALE_A:

    ld.global.cg.b32 %packed, [%rd28];

    shl.b32         %r54, %r51, 5;
    add.u32         %r55, %r20, %r54;
    ld.shared.f32   %x0, [%r55];
    ld.shared.f32   %x1, [%r55 + 4];
    ld.shared.f32   %x2, [%r55 + 8];
    ld.shared.f32   %x3, [%r55 + 12];
    ld.shared.f32   %x4, [%r55 + 16];
    ld.shared.f32   %x5, [%r55 + 20];
    ld.shared.f32   %x6, [%r55 + 24];
    ld.shared.f32   %x7, [%r55 + 28];

    and.b32 %nib, %packed, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x0, %acc;
    shr.b32 %nib, %packed, 4; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x1, %acc;
    shr.b32 %nib, %packed, 8; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x2, %acc;
    shr.b32 %nib, %packed, 12; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x3, %acc;
    shr.b32 %nib, %packed, 16; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x4, %acc;
    shr.b32 %nib, %packed, 20; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x5, %acc;
    shr.b32 %nib, %packed, 24; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x6, %acc;
    shr.b32 %nib, %packed, 28; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x7, %acc;

    add.u64         %rd28, %rd28, %rd20;
    add.u32         %r50, %r50, 1;
    add.u32         %r51, %r51, 1;

    // --- Iteration B ---
    shr.b32         %r53, %r50, 4;
    setp.eq.u32     %p4, %r53, %r45;
    @%p4 bra        SKIP_SCALE_B;
    mov.u32         %r45, %r53;
    cvt.u64.u32     %rd29, %r53;
    mul.lo.u64      %rd30, %rd29, %rd21;
    add.u64         %rd31, %rd25, %rd30;
    ld.global.ca.b16 %htmp, [%rd31];
    cvt.f32.f16     %scale, %htmp;
    mul.f32         %bias, %scale, 0fC1000000;
SKIP_SCALE_B:

    ld.global.cg.b32 %packed, [%rd28];

    shl.b32         %r54, %r51, 5;
    add.u32         %r55, %r20, %r54;
    ld.shared.f32   %x0, [%r55];
    ld.shared.f32   %x1, [%r55 + 4];
    ld.shared.f32   %x2, [%r55 + 8];
    ld.shared.f32   %x3, [%r55 + 12];
    ld.shared.f32   %x4, [%r55 + 16];
    ld.shared.f32   %x5, [%r55 + 20];
    ld.shared.f32   %x6, [%r55 + 24];
    ld.shared.f32   %x7, [%r55 + 28];

    and.b32 %nib, %packed, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x0, %acc;
    shr.b32 %nib, %packed, 4; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x1, %acc;
    shr.b32 %nib, %packed, 8; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x2, %acc;
    shr.b32 %nib, %packed, 12; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x3, %acc;
    shr.b32 %nib, %packed, 16; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x4, %acc;
    shr.b32 %nib, %packed, 20; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x5, %acc;
    shr.b32 %nib, %packed, 24; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x6, %acc;
    shr.b32 %nib, %packed, 28; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x7, %acc;

    add.u64         %rd28, %rd28, %rd20;
    add.u32         %r50, %r50, 1;
    add.u32         %r51, %r51, 1;

    add.u32         %r61, %r61, 1;
    bra             K_LOOP_PAIR;

K_LOOP_PAIR_DONE:
    and.b32         %r62, %r34, 1;
    setp.eq.u32     %p5, %r62, 0;
    @%p5 bra        K_DONE;

    shr.b32         %r53, %r50, 4;
    setp.eq.u32     %p4, %r53, %r45;
    @%p4 bra        SKIP_SCALE_T;
    mov.u32         %r45, %r53;
    cvt.u64.u32     %rd29, %r53;
    mul.lo.u64      %rd30, %rd29, %rd21;
    add.u64         %rd31, %rd25, %rd30;
    ld.global.ca.b16 %htmp, [%rd31];
    cvt.f32.f16     %scale, %htmp;
    mul.f32         %bias, %scale, 0fC1000000;
SKIP_SCALE_T:

    ld.global.cg.b32 %packed, [%rd28];

    shl.b32         %r54, %r51, 5;
    add.u32         %r55, %r20, %r54;
    ld.shared.f32   %x0, [%r55];
    ld.shared.f32   %x1, [%r55 + 4];
    ld.shared.f32   %x2, [%r55 + 8];
    ld.shared.f32   %x3, [%r55 + 12];
    ld.shared.f32   %x4, [%r55 + 16];
    ld.shared.f32   %x5, [%r55 + 20];
    ld.shared.f32   %x6, [%r55 + 24];
    ld.shared.f32   %x7, [%r55 + 28];

    and.b32 %nib, %packed, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x0, %acc;
    shr.b32 %nib, %packed, 4; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x1, %acc;
    shr.b32 %nib, %packed, 8; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x2, %acc;
    shr.b32 %nib, %packed, 12; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x3, %acc;
    shr.b32 %nib, %packed, 16; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x4, %acc;
    shr.b32 %nib, %packed, 20; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x5, %acc;
    shr.b32 %nib, %packed, 24; and.b32 %nib, %nib, 0xF; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x6, %acc;
    shr.b32 %nib, %packed, 28; cvt.rn.f32.u32 %dq, %nib; fma.rn.f32 %dq, %dq, %scale, %bias; fma.rn.f32 %acc, %dq, %x7, %acc;

K_DONE:
    cvt.u64.u32     %rd35, %r11;
    shl.b64         %rd36, %rd35, 2;
    add.u64         %rd37, %rd3, %rd36;
    atom.global.add.f32 %f0, [%rd37], %acc;

DONE:
    ret;
}
