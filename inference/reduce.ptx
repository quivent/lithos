.version 8.0
.target sm_90
.address_size 64

.visible .entry rmsnorm(
    .param .u64 x,
    .param .u64 weight,
    .param .u64 y,
    .param .u32 param_hidden_dim,
    .param .f32 param_eps
)
{
    .shared .align 16 .b8 smem_reduce[1024];
    .reg .pred %p<32>;
    .reg .b32  %r<128>;
    .reg .b64  %rd<64>;
    .reg .f32  %f<128>;

    ld.param.u64 %rd0, [x];
    ld.param.u64 %rd1, [weight];
    ld.param.u64 %rd2, [y];
    ld.param.u32 %r4, [param_hidden_dim];
    ld.param.f32 %f0, [param_eps];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    setp.ge.u32 %p0, %r3, %r4;
    @%p0 bra $L_exit;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f2, [%rd23];
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f3, [%rd23];
    mul.f32 %f4, %f2, %f3;
    mov.f32 %f1, %f4;
    mov.b32 %r6, %f1;
    shfl.sync.bfly.b32 %r5, %r6, 16, 31, -1;
    mov.b32 %f5, %r5;
    add.f32 %f6, %f1, %f5;
    mov.f32 %f1, %f6;
    mov.b32 %r8, %f1;
    shfl.sync.bfly.b32 %r7, %r8, 8, 31, -1;
    mov.b32 %f7, %r7;
    add.f32 %f8, %f1, %f7;
    mov.f32 %f1, %f8;
    mov.b32 %r10, %f1;
    shfl.sync.bfly.b32 %r9, %r10, 4, 31, -1;
    mov.b32 %f9, %r9;
    add.f32 %f10, %f1, %f9;
    mov.f32 %f1, %f10;
    mov.b32 %r12, %f1;
    shfl.sync.bfly.b32 %r11, %r12, 2, 31, -1;
    mov.b32 %f11, %r11;
    add.f32 %f12, %f1, %f11;
    mov.f32 %f1, %f12;
    mov.b32 %r14, %f1;
    shfl.sync.bfly.b32 %r13, %r14, 1, 31, -1;
    mov.b32 %f13, %r13;
    add.f32 %f14, %f1, %f13;
    mov.f32 %f1, %f14;
    rsqrt.approx.f32 %f15, %f1;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f16, [%rd23];
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd1, %rd22;
    ld.global.f32 %f17, [%rd23];
    mul.f32 %f18, %f16, %f17;
    mul.f32 %f19, %f18, %f15;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd2, %rd22;
    st.global.f32 [%rd23], %f19;

$L_exit:
    ret;
}
