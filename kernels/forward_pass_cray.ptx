    ld.shared.f32   %f16, [%r36+12];
    shr.b32         %r38, %r33, 12;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;

    ld.shared.f32   %f16, [%r36+16];
    shr.b32         %r38, %r33, 16;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;

    ld.shared.f32   %f16, [%r36+20];
    shr.b32         %r38, %r33, 20;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;

    ld.shared.f32   %f16, [%r36+24];
    shr.b32         %r38, %r33, 24;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;

    ld.shared.f32   %f16, [%r36+28];
    shr.b32         %r38, %r33, 28;
    and.b32         %r37, %r38, 0x0F;
    cvt.rn.f32.u32  %f17, %r37;
    sub.f32         %f17, %f17, %f13;
    mul.f32         %f17, %f17, %f12;
    fma.rn.f32      %f10, %f17, %f16, %f10;

    add.u32         %r31, %r31, 1;
    bra             LM_PACKED_LOOP;

LM_PACKED_DONE:
    add.u32         %r24, %r24, 1;
    bra             LM_K_GROUP_LOOP;

LM_K_GROUP_DONE:
    shl.b32         %r40, %r20, 2;
    cvt.u64.u32     %rd56, %r40;
    add.u64         %rd57, %rd3, %rd56;
    st.global.f32   [%rd57], %f10;

    add.u32         %r20, %r20, %r5;
    bra             LM_HEAD_TILE_LOOP;

LM_HEAD_DONE:
    ret;
}
