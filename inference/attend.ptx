.version 8.0
.target sm_90
.address_size 64

.visible .entry rope(
    .param .u64 q,
    .param .u64 k,
    .param .u64 q_out,
    .param .u64 k_out,
    .param .u32 param_d_head,
    .param .u32 param_pos
)
{
    .reg .pred %p<32>;
    .reg .b32  %r<128>;
    .reg .b64  %rd<64>;
    .reg .f32  %f<128>;

    ld.param.u64 %rd0, [q];
    ld.param.u64 %rd1, [k];
    ld.param.u64 %rd2, [q_out];
    ld.param.u64 %rd3, [k_out];
    ld.param.u32 %r4, [param_d_head];
    ld.param.u32 %r5, [param_pos];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    cvt.rn.f32.u32 %f0, %r3;
    cvt.rn.f32.u32 %f1, %r4;
    mov.f32 %f3, 0f40000000;
    mul.f32 %f4, %f0, %f3;
    div.approx.f32 %f5, %f4, %f1;
    mov.f32 %f2, %f5;
    cvt.rn.f32.u32 %f6, %r5;
    mul.f32 %f8, %f6, %f2;
    mov.f32 %f7, %f8;
    cos.approx.f32 %f9, %f7;
    sin.approx.f32 %f10, %f7;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f12, [%rd23];
    mov.f32 %f11, %f12;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd1, %rd22;
    ld.global.f32 %f14, [%rd23];
    mov.f32 %f13, %f14;
    mul.f32 %f16, %f11, %f9;
    mul.f32 %f17, %f13, %f10;
    sub.f32 %f18, %f16, %f17;
    mov.f32 %f15, %f18;
    mul.f32 %f20, %f11, %f10;
    mul.f32 %f21, %f13, %f9;
    add.f32 %f22, %f20, %f21;
    mov.f32 %f19, %f22;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd2, %rd22;
    st.global.f32 [%rd23], %f15;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd3, %rd22;
    st.global.f32 [%rd23], %f19;

$L_exit:
    ret;
}
.visible .entry attention_score(
    .param .u64 q,
    .param .u64 k_cache,
    .param .u64 v_cache,
    .param .u64 output,
    .param .u32 param_d_head,
    .param .u32 param_seq_len,
    .param .u32 param_n_q_heads,
    .param .u32 param_n_kv_heads,
    .param .f32 param_scale
)
{
    .reg .pred %p<32>;
    .reg .b32  %r<128>;
    .reg .b64  %rd<64>;
    .reg .f32  %f<128>;

    ld.param.u64 %rd0, [q];
    ld.param.u64 %rd1, [k_cache];
    ld.param.u64 %rd2, [v_cache];
    ld.param.u64 %rd3, [output];
    ld.param.u32 %r4, [param_d_head];
    ld.param.u32 %r5, [param_seq_len];
    ld.param.u32 %r6, [param_n_q_heads];
    ld.param.u32 %r7, [param_n_kv_heads];
    ld.param.f32 %f0, [param_scale];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    setp.ge.u32 %p0, %r3, %r4;
    @%p0 bra $L_exit;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f2, [%rd23];
    mov.f32 %f1, %f2;
    mov.f32 %f4, 0f00000000;
    fma.rn.f32 %f3, %f1, %f0, %f4;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd3, %rd22;
    st.global.f32 [%rd23], %f3;

$L_exit:
    ret;
}
