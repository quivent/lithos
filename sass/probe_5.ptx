.version 8.0
.target sm_90
.address_size 64

.visible .entry probe_shared_mem(
    .param .u64 param_out
)
{
    .reg .f32 %f<10>;
    .reg .u32 %r<10>;
    .reg .u64 %rd<4>;

    .shared .align 16 .b8 smem[1024];

    ld.param.u64 %rd0, [param_out];

    // STS - store to shared memory
    mov.f32 %f0, 0f3F800000;
    mov.f32 %f1, 0f40000000;
    st.shared.f32 [smem], %f0;
    st.shared.f32 [smem+4], %f1;
    st.shared.b32 [smem+8], %r0;
    st.shared.b32 [smem+12], %r1;

    bar.sync 0;

    // LDS - load from shared memory
    ld.shared.f32 %f2, [smem];
    ld.shared.f32 %f3, [smem+4];
    ld.shared.b32 %r2, [smem+8];
    ld.shared.b32 %r3, [smem+12];

    // Store to global
    st.global.f32 [%rd0], %f2;
    st.global.f32 [%rd0+4], %f3;

    ret;
}
