.version 8.0
.target sm_90
.address_size 64

// conv1d REMOVED: was a pointwise multiply, not a causal convolution.
// Replaced by conv1d_infer below.

.visible .entry conv1d_infer(
    .param .u64 input,
    .param .u64 history,
    .param .u64 weights,
    .param .u64 output,
    .param .u32 param_N
)
{
    .reg .pred %p<4>;
    .reg .b32  %r<16>;
    .reg .b64  %rd<16>;
    .reg .f32  %f<16>;

    ld.param.u64 %rd0, [input];
    ld.param.u64 %rd1, [history];
    ld.param.u64 %rd2, [weights];
    ld.param.u64 %rd3, [output];
    ld.param.u32 %r4, [param_N];

    // Global thread index = channel index
    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    // Bounds check
    setp.ge.u32 %p0, %r3, %r4;
    @%p0 bra $L_conv1d_exit;

    // Compute base byte offset: base = channel * 4_taps * 4_bytes = channel * 16
    shl.b32 %r5, %r3, 4;              // r5 = channel * 16 (byte offset for tap 0)
    mul.wide.u32 %rd4, %r5, 1;        // rd4 = base byte offset (64-bit)

    // Pointers to history[channel*4] and weights[channel*4]
    add.u64 %rd5, %rd1, %rd4;         // rd5 = &history[ch*4]
    add.u64 %rd6, %rd2, %rd4;         // rd6 = &weights[ch*4]

    // Load 4 history taps: h0, h1, h2, h3
    ld.global.f32 %f0, [%rd5];        // h[0]
    ld.global.f32 %f1, [%rd5+4];      // h[1]
    ld.global.f32 %f2, [%rd5+8];      // h[2]
    ld.global.f32 %f3, [%rd5+12];     // h[3]

    // Load 4 weight taps: w0, w1, w2, w3
    ld.global.f32 %f4, [%rd6];        // w[0]
    ld.global.f32 %f5, [%rd6+4];      // w[1]
    ld.global.f32 %f6, [%rd6+8];      // w[2]
    ld.global.f32 %f7, [%rd6+12];     // w[3]

    // Accumulate: acc = w0*h0 + w1*h1 + w2*h2 + w3*h3
    mul.f32    %f8, %f4, %f0;         // acc  = w0 * h0
    fma.rn.f32 %f8, %f5, %f1, %f8;   // acc += w1 * h1
    fma.rn.f32 %f8, %f6, %f2, %f8;   // acc += w2 * h2
    fma.rn.f32 %f8, %f7, %f3, %f8;   // acc += w3 * h3

    // Store output
    mul.wide.u32 %rd7, %r3, 4;        // byte offset for output[channel]
    add.u64 %rd8, %rd3, %rd7;
    st.global.f32 [%rd8], %f8;

    // Shift history: h[0]=h[1], h[1]=h[2], h[2]=h[3], h[3]=input[channel]
    st.global.f32 [%rd5],    %f1;     // h[0] = old h[1]
    st.global.f32 [%rd5+4],  %f2;     // h[1] = old h[2]
    st.global.f32 [%rd5+8],  %f3;     // h[2] = old h[3]

    // Load input[channel] and store as h[3]
    mul.wide.u32 %rd9, %r3, 4;
    add.u64 %rd10, %rd0, %rd9;
    ld.global.f32 %f9, [%rd10];       // input[channel]
    st.global.f32 [%rd5+12], %f9;     // h[3] = input[channel]

$L_conv1d_exit:
    ret;
}
.visible .entry gate_sigmoid(
    .param .u64 logit,
    .param .u64 beta,
    .param .u32 param_N
)
{
    .reg .pred %p<32>;
    .reg .b32  %r<128>;
    .reg .b64  %rd<64>;
    .reg .f32  %f<128>;

    ld.param.u64 %rd0, [logit];
    ld.param.u64 %rd1, [beta];
    ld.param.u32 %r4, [param_N];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    setp.ge.u32 %p0, %r3, %r4;
    @%p0 bra $L_exit;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f1, [%rd23];
    mov.f32 %f0, %f1;
    neg.f32 %f2, %f0;
    mov.f32 %f4, 0f3FB8AA3B;
    mul.f32 %f5, %f2, %f4;
    mov.f32 %f3, %f5;
    ex2.approx.f32 %f6, %f3;
    mov.f32 %f8, 0f3F800000;
    add.f32 %f9, %f6, %f8;
    mov.f32 %f7, %f9;
    rcp.approx.f32 %f10, %f7;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd1, %rd22;
    st.global.f32 [%rd23], %f10;

$L_exit:
    ret;
}
.visible .entry deltanet_step(
    .param .u64 state,
    .param .u64 q,
    .param .u64 k,
    .param .u64 v,
    .param .u64 beta_ptr,
    .param .u64 output,
    .param .u32 param_d_state
)
{
    .reg .pred %p<32>;
    .reg .b32  %r<128>;
    .reg .b64  %rd<64>;
    .reg .f32  %f<128>;

    ld.param.u64 %rd0, [state];
    ld.param.u64 %rd1, [q];
    ld.param.u64 %rd2, [k];
    ld.param.u64 %rd3, [v];
    ld.param.u64 %rd4, [beta_ptr];
    ld.param.u64 %rd5, [output];
    ld.param.u32 %r4, [param_d_state];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    setp.ge.u32 %p0, %r3, %r4;
    @%p0 bra $L_exit;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd4, %rd22;
    ld.global.f32 %f1, [%rd23];
    mov.f32 %f0, %f1;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd3, %rd22;
    ld.global.f32 %f3, [%rd23];
    mov.f32 %f2, %f3;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f5, [%rd23];
    mov.f32 %f4, %f5;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd1, %rd22;
    ld.global.f32 %f7, [%rd23];
    mov.f32 %f6, %f7;
    fma.rn.f32 %f4, %f0, %f2, %f4;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    st.global.f32 [%rd23], %f4;
    mov.f32 %f9, 0f00000000;
    fma.rn.f32 %f8, %f4, %f6, %f9;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd5, %rd22;
    st.global.f32 [%rd23], %f8;

$L_exit:
    ret;
}
.visible .entry state_rollback(
    .param .u64 state,
    .param .u64 checkpoint,
    .param .u64 state_out,
    .param .u32 param_N
)
{
    .reg .pred %p<32>;
    .reg .b32  %r<128>;
    .reg .b64  %rd<64>;
    .reg .f32  %f<128>;

    ld.param.u64 %rd0, [state];
    ld.param.u64 %rd1, [checkpoint];
    ld.param.u64 %rd2, [state_out];
    ld.param.u32 %r4, [param_N];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    setp.ge.u32 %p0, %r3, %r4;
    @%p0 bra $L_exit;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd1, %rd22;
    ld.global.f32 %f0, [%rd23];
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd2, %rd22;
    st.global.f32 [%rd23], %f0;

$L_exit:
    ret;
}
