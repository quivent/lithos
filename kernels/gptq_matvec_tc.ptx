K_REDUCE:
    // ================================================================
    // Warp reduction: reduce 32 lanes -> 1 per output column via shuffle
    // Then cross-warp is trivial since each warp handles different columns.
    // ================================================================

    // Reduce f0..f7 across warp lanes
    // f0
    mov.b32 %shfl, %f0;
    shfl.sync.down.b32 %shfl, %shfl, 16, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f0, %f0, %f10;
    mov.b32 %shfl, %f0;
    shfl.sync.down.b32 %shfl, %shfl, 8, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f0, %f0, %f10;
    mov.b32 %shfl, %f0;
    shfl.sync.down.b32 %shfl, %shfl, 4, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f0, %f0, %f10;
    mov.b32 %shfl, %f0;
    shfl.sync.down.b32 %shfl, %shfl, 2, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f0, %f0, %f10;
    mov.b32 %shfl, %f0;
    shfl.sync.down.b32 %shfl, %shfl, 1, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f0, %f0, %f10;

    // f1
    mov.b32 %shfl, %f1;
    shfl.sync.down.b32 %shfl, %shfl, 16, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f1, %f1, %f10;
    mov.b32 %shfl, %f1;
    shfl.sync.down.b32 %shfl, %shfl, 8, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f1, %f1, %f10;
    mov.b32 %shfl, %f1;
    shfl.sync.down.b32 %shfl, %shfl, 4, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f1, %f1, %f10;
    mov.b32 %shfl, %f1;
    shfl.sync.down.b32 %shfl, %shfl, 2, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f1, %f1, %f10;
    mov.b32 %shfl, %f1;
    shfl.sync.down.b32 %shfl, %shfl, 1, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f1, %f1, %f10;

    // f2
    mov.b32 %shfl, %f2;
    shfl.sync.down.b32 %shfl, %shfl, 16, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f2, %f2, %f10;
    mov.b32 %shfl, %f2;
    shfl.sync.down.b32 %shfl, %shfl, 8, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f2, %f2, %f10;
    mov.b32 %shfl, %f2;
    shfl.sync.down.b32 %shfl, %shfl, 4, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f2, %f2, %f10;
    mov.b32 %shfl, %f2;
    shfl.sync.down.b32 %shfl, %shfl, 2, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f2, %f2, %f10;
    mov.b32 %shfl, %f2;
    shfl.sync.down.b32 %shfl, %shfl, 1, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f2, %f2, %f10;

    // f3
    mov.b32 %shfl, %f3;
    shfl.sync.down.b32 %shfl, %shfl, 16, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f3, %f3, %f10;
    mov.b32 %shfl, %f3;
    shfl.sync.down.b32 %shfl, %shfl, 8, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f3, %f3, %f10;
    mov.b32 %shfl, %f3;
    shfl.sync.down.b32 %shfl, %shfl, 4, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f3, %f3, %f10;
    mov.b32 %shfl, %f3;
    shfl.sync.down.b32 %shfl, %shfl, 2, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f3, %f3, %f10;
    mov.b32 %shfl, %f3;
    shfl.sync.down.b32 %shfl, %shfl, 1, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f3, %f3, %f10;

    // f4
    mov.b32 %shfl, %f4;
    shfl.sync.down.b32 %shfl, %shfl, 16, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f4, %f4, %f10;
