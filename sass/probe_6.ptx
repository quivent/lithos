.version 8.0
.target sm_90
.address_size 64

.visible .entry probe_shfl(
    .param .u64 param_out
)
{
    .reg .u32 %r<20>;
    .reg .u64 %rd<4>;
    .reg .pred %p<4>;

    ld.param.u64 %rd0, [param_out];

    mov.u32 %r0, 42;
    mov.u32 %r10, 0x1f;  // mask

    // SHFL.BFLY (butterfly/xor)
    shfl.sync.bfly.b32 %r1, %r0, 1, %r10, 0xFFFFFFFF;

    // SHFL.DOWN
    shfl.sync.down.b32 %r2, %r0, 1, %r10, 0xFFFFFFFF;

    // SHFL.UP
    shfl.sync.up.b32 %r3, %r0, 1, %r10, 0xFFFFFFFF;

    // SHFL.IDX
    shfl.sync.idx.b32 %r4, %r0, 0, %r10, 0xFFFFFFFF;

    // Store results
    st.global.u32 [%rd0], %r1;
    st.global.u32 [%rd0+4], %r2;
    st.global.u32 [%rd0+8], %r3;
    st.global.u32 [%rd0+12], %r4;

    ret;
}
