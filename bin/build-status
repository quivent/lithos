#!/usr/bin/env bash
# build-status — regenerate docs/status.html from PLAN.md
# Uses the site's CSS/nav pattern. No dependencies beyond shell.
set -eu
cd "$(dirname "$0")/.."

NAV='<nav>
<div class="container">
  <a href="/" class="nav-brand">Lithos</a>
  <a href="/">Home</a>
  <a href="/architecture">Architecture</a>
  <a href="/kernels">Kernels</a>
  <a href="/quantization">Quantization</a>
  <a href="/compiler">The Compiler</a>
  <a href="/pipeline">Inference Stack</a>
  <a href="/roadmap">Architecture Roadmap</a>
  <a href="/status" class="active">Status</a>
  <a href="/language">Language Reference</a>
  <a href="/performance">Performance</a>
  <a href="/glossary">Glossary</a>
</div>
</nav>'

# Convert PLAN.md → HTML body
# Handle: headers, code blocks, checkboxes, bold, links
body=$(awk '
BEGIN { in_code=0; in_list=0 }
/^```/ {
  if (in_code) { print "</code></pre>"; in_code=0 }
  else { print "<pre class=\"code\"><code>"; in_code=1 }
  next
}
in_code { gsub(/&/,"\\&amp;"); gsub(/</,"\\&lt;"); gsub(/>/,"\\&gt;"); print; next }
/^# / { gsub(/^# /,""); printf "<h1>%s</h1>\n",$0; next }
/^## / { gsub(/^## /,""); printf "<h2>%s</h2>\n",$0; next }
/^### / { gsub(/^### /,""); printf "<h3>%s</h3>\n",$0; next }
/^---$/ { print "<hr>"; next }
/^$/ { if (in_list) { print "</ul>"; in_list=0 }; print ""; next }
/^\[✓\]/ || /^\[x\]/ {
  if (!in_list) { print "<ul class=\"checklist\">"; in_list=1 }
  gsub(/^\[✓\] */,""); gsub(/^\[x\] */,"")
  printf "<li class=\"done\">✓ %s</li>\n",$0; next
}
/^\[ \]/ {
  if (!in_list) { print "<ul class=\"checklist\">"; in_list=1 }
  gsub(/^\[ \] */,"")
  printf "<li class=\"todo\">○ %s</li>\n",$0; next
}
/^[0-9]+\. \*\*/ {
  if (!in_list) { print "<ol class=\"blockers\">"; in_list=1 }
  gsub(/^[0-9]+\. /,"")
  gsub(/\*\*/,"<strong>"); gsub(/\*\*/,"</strong>")
  printf "<li>%s</li>\n",$0; next
}
/^- / {
  if (!in_list) { print "<ul>"; in_list=1 }
  gsub(/^- /,"")
  printf "<li>%s</li>\n",$0; next
}
{
  if (in_list) { print "</ul>"; in_list=0 }
  gsub(/\*\*([^*]+)\*\*/,"<strong>\\1</strong>")
  gsub(/`([^`]+)`/,"<code>\\1</code>")
  printf "<p>%s</p>\n",$0
}
END { if (in_list) print "</ul>" }
' PLAN.md)

# Post-process: colorize checkmarks and BLOCKING inside code blocks
body=$(echo "$body" | sed \
  -e 's/\[✓\]/<span style="color:#7ec87e">✓<\/span>/g' \
  -e 's/\[x\]/<span style="color:#7ec87e">✓<\/span>/g' \
  -e 's/\[ \]/<span style="color:#d06e6e">○<\/span>/g' \
  -e 's/← BLOCKING/<span style="color:#d06e6e;font-weight:600">← BLOCKING<\/span>/g' \
  -e 's/████/<span style="color:#7ec87e">████<\/span>/g' \
  -e 's/░░░░/<span style="color:#d06e6e">░░░░<\/span>/g')

cat > docs/status.html << HTMLEOF
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lithos Status</title>
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --bg: #0a0a0f; --bg-raised: #10101a; --bg-code: #0e0e18;
  --text: #e0e0e8; --text-dim: #888898; --text-faint: #555568;
  --accent: #d4a053; --accent-dim: #a07830;
  --cyan: #6ec8d0; --green: #7ec87e; --blue: #6e8ed0; --red: #d06e6e;
  --border: #1a1a28;
}
html { font-size: 15px; scroll-behavior: smooth; }
body {
  background: var(--bg); color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  line-height: 1.65; -webkit-font-smoothing: antialiased;
}
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }
.container { max-width: 960px; margin: 0 auto; padding: 0 2rem; }
nav {
  position: sticky; top: 0; z-index: 100;
  background: var(--bg); border-bottom: 1px solid var(--border);
  padding: 0.6rem 0; font-size: 0.8rem; letter-spacing: 0.04em;
}
nav .container { display: flex; gap: 1.8rem; flex-wrap: wrap; align-items: center; }
nav a { color: var(--text-dim); }
nav a:hover { color: var(--accent); text-decoration: none; }
nav .nav-brand { color: var(--accent); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.75rem; }
nav a.active { color: var(--accent); }
.hero { padding: 5rem 0 3.5rem 0; border-bottom: 1px solid var(--border); }
.hero h1 { font-size: 2.8rem; font-weight: 300; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text); margin-bottom: 0.5rem; }
.hero p { color: var(--text-dim); font-size: 1.1rem; letter-spacing: 0.06em; }
section { padding: 3.5rem 0; border-bottom: 1px solid var(--border); }
section:last-child { border-bottom: none; }
h1 { font-size: 2rem; font-weight: 300; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; }
h2 { font-size: 1.4rem; font-weight: 300; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; margin-top: 3rem; }
h3 { font-size: 1rem; font-weight: 300; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-dim); margin: 2rem 0 0.8rem 0; }
p { margin-bottom: 1rem; }
hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
pre.code {
  background: var(--bg-code); border: 1px solid var(--border); border-radius: 6px;
  padding: 1.2rem 1.5rem; overflow-x: auto; font-size: 0.85rem;
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  line-height: 1.5; margin: 1rem 0;
}
code { font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace; font-size: 0.88em; background: var(--bg-code); padding: 0.15em 0.4em; border-radius: 3px; }
pre.code code { background: none; padding: 0; }
strong { color: var(--accent); font-weight: 600; }
ul, ol { margin: 0.5rem 0 1rem 1.5rem; }
li { margin-bottom: 0.3rem; }
ul.checklist { list-style: none; margin-left: 0; }
ul.checklist li { padding: 0.3rem 0; font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace; font-size: 0.88rem; }
ul.checklist li.done { color: var(--green); }
ul.checklist li.todo { color: var(--red); }
ol.blockers { margin-left: 1.5rem; }
ol.blockers li { margin-bottom: 0.5rem; }
ol.blockers strong { color: var(--red); }
.timestamp { color: var(--text-faint); font-size: 0.8rem; margin-top: 3rem; text-align: center; }
</style>
</head>
<body>
${NAV}
<div class="container" style="padding-top:2rem; padding-bottom:4rem;">
${body}
<p class="timestamp">Generated from PLAN.md — $(date -u '+%Y-%m-%d %H:%M UTC')</p>
</div>
</body>
</html>
HTMLEOF

echo "docs/status.html generated from PLAN.md"
