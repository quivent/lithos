.version 8.0
.target sm_90
.address_size 64

.visible .entry probe_sync(
    .param .u64 param_out
)
{
    .reg .f32 %f<4>;
    .reg .u64 %rd<4>;

    ld.param.u64 %rd0, [param_out];

    mov.f32 %f0, 0f3F800000;

    // BAR.SYNC (barrier)
    bar.sync 0;

    // MEMBAR - different scopes
    membar.cta;
    membar.gl;
    membar.sys;

    st.global.f32 [%rd0], %f0;

    // Another barrier
    bar.sync 0;

    ret;
}
