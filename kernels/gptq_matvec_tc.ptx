    mov.b32 %shfl, %f6;
    shfl.sync.down.b32 %shfl, %shfl, 1, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f6, %f6, %f10;

    // f7
    mov.b32 %shfl, %f7;
    shfl.sync.down.b32 %shfl, %shfl, 16, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f7, %f7, %f10;
    mov.b32 %shfl, %f7;
    shfl.sync.down.b32 %shfl, %shfl, 8, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f7, %f7, %f10;
    mov.b32 %shfl, %f7;
    shfl.sync.down.b32 %shfl, %shfl, 4, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f7, %f7, %f10;
    mov.b32 %shfl, %f7;
    shfl.sync.down.b32 %shfl, %shfl, 2, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f7, %f7, %f10;
    mov.b32 %shfl, %f7;
    shfl.sync.down.b32 %shfl, %shfl, 1, 31, 0xFFFFFFFF; mov.b32 %f10, %shfl; add.f32 %f7, %f7, %f10;

    // ================================================================
    // Only lane 0 of each warp stores
    // ================================================================
    setp.ne.u32     %p6, %r6, 0;
    @%p6 bra        DONE;

    // Store 8 outputs for this warp
    // Global col = tile_origin + warp_id * 8 + c
    // output addr = output_ptr + global_col * 4

    // col 0
    add.u32         %r60, %r34, 0;
    setp.lt.u32     %p7, %r60, %r0;
    @!%p7 bra       DONE;
    cvt.u64.u32     %rd50, %r60;
    shl.b64         %rd51, %rd50, 2;
    add.u64         %rd52, %rd3, %rd51;
    st.global.f32   [%rd52], %f0;

    // col 1
    add.u32         %r60, %r34, 1;
    setp.lt.u32     %p7, %r60, %r0;
    @!%p7 bra       DONE;
