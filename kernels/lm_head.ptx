// lm_head.ptx -- Dense FP16 matrix-vector multiply for lm_head projection
//
// Computes: output[n] = dot(weight[n, :], input[:])
//   where weight is [248320, 5120] in FP16 row-major
//   and input is [5120] in F32
//
// Params: weight_ptr (u64, FP16), input_ptr (u64, F32), output_ptr (u64, F32)
//
// Launch: grid=(vocab_size/8, 1, 1), block=(256, 1, 1), shared_mem=20736
// Each block computes 8 output elements. 256 threads stride over hidden_dim.
// Input vector cached in shared memory. Warp shuffle + shared mem reduction.
//
// ROWS_PER_BLOCK = 8

.version 8.5
.target sm_90
.address_size 64

.visible .entry lm_head(
    .param .u64 weight_ptr,
    .param .u64 input_ptr,
    .param .u64 output_ptr
)
{
    .reg .u64   %rd<40>;
    .reg .u32   %r<70>;
    .reg .f32   %f<40>;
    .reg .pred  %p<10>;
    .reg .b32   %shfl_tmp;
    .reg .b16   %h0, %h1, %h2, %h3;

    // Shared memory layout:
    // smem[0..63]    = warp_sums: 8 rows * 8 warps = 64 floats = 256 bytes
    // smem[64..5183] = input cache: 5120 floats = 20480 bytes
    // Total: 20736 bytes
    .shared .align 4 .f32 smem[5184];

    // Load params
    ld.param.u64    %rd0, [weight_ptr];
    ld.param.u64    %rd1, [input_ptr];
    ld.param.u64    %rd2, [output_ptr];

    // base_row = blockIdx.x * 8
    mov.u32         %r0, %ctaid.x;
    shl.b32         %r0, %r0, 3;

    mov.u32         %r1, %tid.x;
    mov.u32         %r2, %ntid.x;       // 256
    mov.u32         %r3, 5120;

    // --- Load input vector into shared memory ---
    mov.u32         %r51, smem;
    add.u32         %r52, %r51, 256;     // input_smem = smem + 64*4

    mov.u32         %r5, %r1;
LOAD_INPUT:
    setp.ge.u32     %p0, %r5, %r3;
    @%p0 bra        LOAD_INPUT_DONE;
    shl.b32         %r6, %r5, 2;
    cvt.u64.u32     %rd3, %r6;
    add.u64         %rd4, %rd1, %rd3;
    ld.global.f32   %f10, [%rd4];
    add.u32         %r7, %r52, %r6;
    st.shared.f32   [%r7], %f10;
    add.u32         %r5, %r5, %r2;
    bra             LOAD_INPUT;
LOAD_INPUT_DONE:
    bar.sync        0;

    // --- Base addresses for 8 weight rows ---
    // row_bytes = 5120 * 2 = 10240
    mul.lo.u32      %r10, %r0, 10240;
    cvt.u64.u32     %rd5, %r10;
    add.u64         %rd10, %rd0, %rd5;   // row 0
    add.u64         %rd11, %rd10, 10240; // row 1
    add.u64         %rd12, %rd11, 10240; // row 2
    add.u64         %rd13, %rd12, 10240; // row 3
    add.u64         %rd14, %rd13, 10240; // row 4
    add.u64         %rd15, %rd14, 10240; // row 5
    add.u64         %rd16, %rd15, 10240; // row 6
    add.u64         %rd17, %rd16, 10240; // row 7

    // 8 accumulators
    mov.f32         %f0, 0f00000000;
    mov.f32         %f1, 0f00000000;
    mov.f32         %f2, 0f00000000;
    mov.f32         %f3, 0f00000000;
    mov.f32         %f4, 0f00000000;
    mov.f32         %f5, 0f00000000;
    mov.f32         %f6, 0f00000000;
    mov.f32         %f7, 0f00000000;

    mov.u32         %r5, %r1;

K_LOOP:
    setp.ge.u32     %p1, %r5, %r3;
    @%p1 bra        K_DONE;

    // Load input[k] from shared memory
    shl.b32         %r6, %r5, 2;
    add.u32         %r7, %r52, %r6;
    ld.shared.f32   %f10, [%r7];

    // Column byte offset in FP16 = k * 2
    shl.b32         %r8, %r5, 1;
    cvt.u64.u32     %rd6, %r8;

    // Row 0
    add.u64         %rd7, %rd10, %rd6;
    ld.global.b16   %h0, [%rd7];
    cvt.f32.f16     %f11, %h0;
    fma.rn.f32      %f0, %f11, %f10, %f0;

    // Row 1
    add.u64         %rd7, %rd11, %rd6;
    ld.global.b16   %h1, [%rd7];
    cvt.f32.f16     %f12, %h1;
    fma.rn.f32      %f1, %f12, %f10, %f1;

    // Row 2
    add.u64         %rd7, %rd12, %rd6;
    ld.global.b16   %h2, [%rd7];
    cvt.f32.f16     %f13, %h2;
    fma.rn.f32      %f2, %f13, %f10, %f2;

    // Row 3
    add.u64         %rd7, %rd13, %rd6;
    ld.global.b16   %h3, [%rd7];
    cvt.f32.f16     %f14, %h3;
    fma.rn.f32      %f3, %f14, %f10, %f3;

    // Row 4
    add.u64         %rd7, %rd14, %rd6;
    ld.global.b16   %h0, [%rd7];
    cvt.f32.f16     %f11, %h0;
    fma.rn.f32      %f4, %f11, %f10, %f4;

    // Row 5
    add.u64         %rd7, %rd15, %rd6;
    ld.global.b16   %h1, [%rd7];
    cvt.f32.f16     %f12, %h1;
    fma.rn.f32      %f5, %f12, %f10, %f5;

    // Row 6
    add.u64         %rd7, %rd16, %rd6;
    ld.global.b16   %h2, [%rd7];
    cvt.f32.f16     %f13, %h2;
    fma.rn.f32      %f6, %f13, %f10, %f6;

    // Row 7
    add.u64         %rd7, %rd17, %rd6;
    ld.global.b16   %h3, [%rd7];
    cvt.f32.f16     %f14, %h3;
    fma.rn.f32      %f7, %f14, %f10, %f7;

    add.u32         %r5, %r5, %r2;
    bra             K_LOOP;

K_DONE:
    // --- Warp shuffle reduction for all 8 accumulators ---
    // Macro-like pattern: reduce %fN for each row

    // Row 0
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;
    mov.b32 %shfl_tmp, %f0;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f0, %f0, %f20;

    // Row 1
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;
    mov.b32 %shfl_tmp, %f1;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f1, %f1, %f20;

    // Row 2
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;
    mov.b32 %shfl_tmp, %f2;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f2, %f2, %f20;

    // Row 3
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;
    mov.b32 %shfl_tmp, %f3;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f3, %f3, %f20;

    // Row 4
    mov.b32 %shfl_tmp, %f4;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f4, %f4, %f20;
    mov.b32 %shfl_tmp, %f4;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f4, %f4, %f20;
    mov.b32 %shfl_tmp, %f4;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f4, %f4, %f20;
    mov.b32 %shfl_tmp, %f4;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f4, %f4, %f20;
    mov.b32 %shfl_tmp, %f4;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f4, %f4, %f20;

    // Row 5
    mov.b32 %shfl_tmp, %f5;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f5, %f5, %f20;
    mov.b32 %shfl_tmp, %f5;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f5, %f5, %f20;
    mov.b32 %shfl_tmp, %f5;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f5, %f5, %f20;
    mov.b32 %shfl_tmp, %f5;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f5, %f5, %f20;
    mov.b32 %shfl_tmp, %f5;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f5, %f5, %f20;

    // Row 6
    mov.b32 %shfl_tmp, %f6;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f6, %f6, %f20;
    mov.b32 %shfl_tmp, %f6;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f6, %f6, %f20;
    mov.b32 %shfl_tmp, %f6;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f6, %f6, %f20;
    mov.b32 %shfl_tmp, %f6;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f6, %f6, %f20;
    mov.b32 %shfl_tmp, %f6;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f6, %f6, %f20;

    // Row 7
    mov.b32 %shfl_tmp, %f7;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 16, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f7, %f7, %f20;
    mov.b32 %shfl_tmp, %f7;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 8, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f7, %f7, %f20;
    mov.b32 %shfl_tmp, %f7;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 4, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f7, %f7, %f20;
    mov.b32 %shfl_tmp, %f7;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 2, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f7, %f7, %f20;
    mov.b32 %shfl_tmp, %f7;
    shfl.sync.down.b32 %shfl_tmp, %shfl_tmp, 1, 31, 0xFFFFFFFF;
    mov.b32 %f20, %shfl_tmp; add.f32 %f7, %f7, %f20;

    // --- Lane 0 of each warp stores 8 sums to shared memory ---
    shr.b32         %r30, %r1, 5;        // warp_id
    and.b32         %r31, %r1, 31;       // lane

    setp.eq.u32     %p2, %r31, 0;

    // warp_sums layout: [row * 8 + warp_id], each entry 4 bytes
    // Row r: smem + (r * 8 + warp_id) * 4
    mov.u32         %r51, smem;
    shl.b32         %r32, %r30, 2;       // warp_id * 4

    // Row 0: smem[warp_id]
    add.u32         %r33, %r51, %r32;
    @%p2 st.shared.f32 [%r33], %f0;
    // Row 1: smem[8 + warp_id]
    add.u32         %r34, %r33, 32;      // 8 * 4 = 32 bytes
    @%p2 st.shared.f32 [%r34], %f1;
    // Row 2
    add.u32         %r35, %r34, 32;
    @%p2 st.shared.f32 [%r35], %f2;
    // Row 3
    add.u32         %r36, %r35, 32;
    @%p2 st.shared.f32 [%r36], %f3;
    // Row 4
    add.u32         %r37, %r36, 32;
    @%p2 st.shared.f32 [%r37], %f4;
    // Row 5
    add.u32         %r38, %r37, 32;
    @%p2 st.shared.f32 [%r38], %f5;
    // Row 6
    add.u32         %r39, %r38, 32;
    @%p2 st.shared.f32 [%r39], %f6;
    // Row 7
    add.u32         %r40, %r39, 32;
    @%p2 st.shared.f32 [%r40], %f7;

    bar.sync        0;

    // --- Threads 0-7 each sum one row across warps ---
    // Thread t (0..7) handles row t
    setp.ge.u32     %p3, %r1, 8;
    @%p3 bra        DONE;

    shr.b32         %r41, %r2, 5;        // num_warps = 8

    // smem offset for row %r1: smem + r1 * 8 * 4 = smem + r1 * 32
    shl.b32         %r42, %r1, 5;        // r1 * 32
    mov.u32         %r51, smem;
    add.u32         %r43, %r51, %r42;    // base for this row's warp sums

    mov.f32         %f25, 0f00000000;
    mov.u32         %r44, 0;
SUM_WARPS:
    setp.ge.u32     %p4, %r44, %r41;
    @%p4 bra        SUM_WARPS_DONE;
    shl.b32         %r45, %r44, 2;
    add.u32         %r46, %r43, %r45;
    ld.shared.f32   %f26, [%r46];
    add.f32         %f25, %f25, %f26;
    add.u32         %r44, %r44, 1;
    bra             SUM_WARPS;
SUM_WARPS_DONE:

    // Store output[base_row + r1]
    add.u32         %r47, %r0, %r1;      // base_row + thread_id (0..7)
    cvt.u64.u32     %rd20, %r47;
    shl.b64         %rd20, %rd20, 2;     // * 4
    add.u64         %rd21, %rd2, %rd20;
    st.global.f32   [%rd21], %f25;

DONE:
    ret;
}
