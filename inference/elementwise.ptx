    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f0, [%rd23];
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd1, %rd22;
    ld.global.f32 %f1, [%rd23];
    mul.f32 %f2, %f0, %f1;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd2, %rd22;
    st.global.f32 [%rd23], %f2;

$L_exit:
    ret;
}
.visible .entry activate_silu(
    .param .u64 x,
    .param .u64 output
)
{
    .reg .pred %p<32>;
    .reg .b32  %r<128>;
    .reg .b64  %rd<64>;
    .reg .f32  %f<128>;

    ld.param.u64 %rd0, [x];
    ld.param.u64 %rd1, [output];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f1, [%rd23];
    mov.f32 %f0, %f1;
    neg.f32 %f2, %f0;
    mov.f32 %f4, 0f3FB8AA3B;
    mul.f32 %f5, %f2, %f4;
    mov.f32 %f3, %f5;
    ex2.approx.f32 %f6, %f3;
    mov.f32 %f8, 0f3F800000;
    add.f32 %f9, %f6, %f8;
    mov.f32 %f7, %f9;
    rcp.approx.f32 %f10, %f7;
    mul.f32 %f12, %f0, %f10;
    mov.f32 %f11, %f12;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd1, %rd22;
    st.global.f32 [%rd23], %f11;

$L_exit:
    ret;
}
.visible .entry scale(
    .param .u64 x,
    .param .u64 factor,
    .param .u64 output
)
{
    .reg .pred %p<32>;
    .reg .b32  %r<128>;
    .reg .b64  %rd<64>;
    .reg .f32  %f<128>;

    ld.param.u64 %rd0, [x];
    ld.param.u64 %rd1, [factor];
    ld.param.u64 %rd2, [output];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f0, [%rd23];
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd1, %rd22;
    ld.global.f32 %f1, [%rd23];
    mul.f32 %f2, %f0, %f1;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd2, %rd22;
    st.global.f32 [%rd23], %f2;

$L_exit:
    ret;
}
