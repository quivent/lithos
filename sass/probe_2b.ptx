.version 8.0
.target sm_90
.address_size 64

.visible .entry probe_mufu_b(
    .param .u64 param_in,
    .param .u64 param_out
)
{
    .reg .f32 %f<20>;
    .reg .u64 %rd<4>;

    ld.param.u64 %rd0, [param_in];
    ld.param.u64 %rd1, [param_out];

    // Load value from memory to prevent constant folding
    ld.global.f32 %f0, [%rd0];
    ld.global.f32 %f1, [%rd0+4];

    // RCP (reciprocal)
    rcp.approx.f32 %f2, %f0;

    // RSQRT
    rsqrt.approx.f32 %f3, %f0;

    // EX2 (2^x)
    ex2.approx.f32 %f4, %f1;

    // LG2 (log2)
    lg2.approx.f32 %f5, %f0;

    // SIN
    sin.approx.f32 %f6, %f1;

    // COS
    cos.approx.f32 %f7, %f1;

    // SQRT (via rsqrt + rcp or native sqrt)
    sqrt.approx.f32 %f8, %f0;

    // Store all
    st.global.f32 [%rd1], %f2;
    st.global.f32 [%rd1+4], %f3;
    st.global.f32 [%rd1+8], %f4;
    st.global.f32 [%rd1+12], %f5;
    st.global.f32 [%rd1+16], %f6;
    st.global.f32 [%rd1+20], %f7;
    st.global.f32 [%rd1+24], %f8;

    ret;
}
