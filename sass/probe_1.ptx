.version 8.0
.target sm_90
.address_size 64

.visible .entry probe_float_arith(
    .param .u64 param_out
)
{
    .reg .f32 %f<20>;
    .reg .pred %p<4>;
    .reg .u64 %rd<4>;

    // Load base address
    ld.param.u64 %rd0, [param_out];

    // Use some initial values
    mov.f32 %f0, 0f3F800000;  // 1.0
    mov.f32 %f1, 0f40000000;  // 2.0
    mov.f32 %f2, 0fBF800000;  // -1.0

    // FMUL
    mul.f32 %f3, %f0, %f1;

    // FMIN
    min.f32 %f4, %f0, %f1;

    // FMAX
    max.f32 %f5, %f0, %f1;

    // FNEG (negate via mul by -1, or use neg)
    neg.f32 %f6, %f0;

    // FABS
    abs.f32 %f7, %f2;

    // FSETP
    setp.gt.f32 %p0, %f0, %f1;
    setp.lt.f32 %p1, %f0, %f1;
    setp.eq.f32 %p2, %f0, %f1;

    // Store results to prevent optimization
    st.global.f32 [%rd0], %f3;
    st.global.f32 [%rd0+4], %f4;
    st.global.f32 [%rd0+8], %f5;
    st.global.f32 [%rd0+12], %f6;
    st.global.f32 [%rd0+16], %f7;

    // Use predicates
    @%p0 st.global.f32 [%rd0+20], %f0;
    @%p1 st.global.f32 [%rd0+24], %f1;

    ret;
}
