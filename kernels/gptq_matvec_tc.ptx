// gptq_matvec_tc.ptx -- Tensor-core optimized GPTQ W4A16 GEMV for single-token decode
//
// Computes: output[n] = sum_k( dequant(qweight[k/8, n], k%8) * input[k] )
//   where dequant(packed, bit) = ((packed >> (bit*4)) & 0xF - 7) * scales[k/128, n]
//
// qweight layout: [K/8, N] int32 row-major, each i32 has 8 x 4-bit weights
// scales layout:  [K/128, N] float16 row-major
// input layout:   [K] float32
// output layout:  [N] float32
//
// Params: qweight_ptr (u64), scales_ptr (u64), input_ptr (u64), output_ptr (u64),
//         N (u32), K (u32)
//
// Launch: grid=(ceil(N/64), 1, 1), block=(128, 1, 1)
// Each block computes 64 output elements (vs 1 per block in baseline).
//
// Architecture:
//   128 threads = 4 warps. Each warp handles 16 output columns.
//   Within a warp, 32 threads cooperatively reduce along K.
//   Uses mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 tensor cores.
//
//   To preserve f32 precision on the input vector:
//   - Input loaded to shared memory as f32 (once per block)
//   - For each K-tile of 16: input f32 is split into f16 + residual_f16
//     input_f16 = cvt.rn.f16(input_f32)
//     residual_f32 = input_f32 - cvt.f32(input_f16)
//     residual_f16 = cvt.rn.f16(residual_f32)
//   - Two MMAs are issued: main + residual, results accumulated
//   This achieves near-f32 precision for the input contribution.
//
//   Weight dequantization (INT32 -> f16) happens in registers from global loads.
//   Dequantized f16 weights stored to shared memory for ldmatrix/MMA consumption.
//
// Shared memory layout:
//   X_smem:  K * 4 bytes (input vector, f32)           = 20480 B for K=5120
//   B_smem:  16 * 64 * 2 bytes (dequant f16 weights)   = 2048 B (single buffer)
//   S_smem:  64 * 2 bytes (f16 scales)                 = 128 B
//   Total: ~22 KB

.version 8.5
.target sm_90
.address_size 64

.visible .entry gptq_matvec_tc(
    .param .u64 qweight_ptr,
    .param .u64 scales_ptr,
    .param .u64 input_ptr,
    .param .u64 output_ptr,
    .param .u32 param_N,
    .param .u32 param_K
)
{
    .reg .u64   %rd<100>;
    .reg .u32   %r<200>;
    .reg .f32   %f<100>;
    .reg .f16x2 %h<32>;
    .reg .b32   %b<64>;
    .reg .pred  %p<32>;
    .reg .b16   %htmp<8>;

    .shared .align 16 .b8 X_smem[20480];   // K * 4 bytes (f32), max K=5120
    .shared .align 16 .b8 B_smem[2048];    // 16 * 64 * 2B dequantized f16 weights
    .shared .align 16 .b8 S_smem[128];     // 64 f16 scales

    // ---- Load parameters ----
    ld.param.u64    %rd0, [qweight_ptr];
    ld.param.u64    %rd1, [scales_ptr];
    ld.param.u64    %rd2, [input_ptr];
    ld.param.u64    %rd3, [output_ptr];
    ld.param.u32    %r0,  [param_N];
    ld.param.u32    %r1,  [param_K];

    // ---- Thread/block identity ----
    mov.u32         %r3,  %tid.x;          // 0..127
    mov.u32         %r4,  %ctaid.x;        // block index (N-tile)

    and.b32         %r6,  %r3, 31;         // lane id (0..31)
    shr.b32         %r7,  %r3, 5;          // warp id (0..3)

    // N-tile origin: ctaid.x * 64
    shl.b32         %r10, %r4, 6;

    // Early exit if tile fully OOB
    setp.ge.u32     %p0, %r10, %r0;
    @%p0 bra        DONE;

    // ================================================================
    // STEP 1: Load input vector into shared memory as f32
    // 128 threads, K f32 elements. Each thread loads K/128 elements.
    // ================================================================
    mov.u32         %r20, X_smem;
    mov.u32         %r21, %r3;             // start index = tid
LOAD_X:
    setp.ge.u32     %p1, %r21, %r1;
    @%p1 bra        LOAD_X_DONE;

    cvt.u64.u32     %rd10, %r21;
    shl.b64         %rd11, %rd10, 2;       // byte offset = idx * 4
    add.u64         %rd12, %rd2, %rd11;
    ld.global.f32   %f40, [%rd12];

    shl.b32         %r22, %r21, 2;         // byte offset in smem = idx * 4
    add.u32         %r23, %r20, %r22;
    st.shared.f32   [%r23], %f40;

    add.u32         %r21, %r21, 128;
    bra             LOAD_X;
LOAD_X_DONE:
    bar.sync        0;

    // ================================================================
    // STEP 2: Initialize accumulators
    // Each warp: 2 n-tiles of 8 cols = 16 cols.
    // Each n-tile MMA has 4 f32 accumulators per thread.
    // We do main + residual = same accumulators (accumulated).
    // ================================================================
    mov.f32         %f0,  0f00000000;
    mov.f32         %f1,  0f00000000;
    mov.f32         %f2,  0f00000000;
    mov.f32         %f3,  0f00000000;
    mov.f32         %f4,  0f00000000;
    mov.f32         %f5,  0f00000000;
    mov.f32         %f6,  0f00000000;
    mov.f32         %f7,  0f00000000;

    // ================================================================
    // STEP 3: Weight/scale addressing setup
    // ================================================================
    // Thread mapping for packed weight loading:
    //   128 threads load 2 packed rows * 64 cols = 128 int32 values
    //   tid -> packed_row = tid / 64 (0 or 1), packed_col = tid % 64
    shr.b32         %r30, %r3, 6;          // packed_row (0 or 1)
    and.b32         %r31, %r3, 63;         // packed_col (0..63)

    // Global column for this thread's weight
    add.u32         %r32, %r10, %r31;      // tile_origin + packed_col

    // qweight row stride in bytes: N * 4
    shl.b32         %r33, %r0, 2;
    cvt.u64.u32     %rd20, %r33;

    // Column byte offset: global_col * 4
    shl.b32         %r34, %r32, 2;
    cvt.u64.u32     %rd21, %r34;

    // Scales row stride: N * 2 bytes
    shl.b32         %r35, %r0, 1;
    cvt.u64.u32     %rd22, %r35;

    // B_smem and S_smem bases
    mov.u32         %r40, B_smem;
    mov.u32         %r41, S_smem;

    // Precompute: packed_row * 8 (for nibble K offset)
    shl.b32         %r42, %r30, 3;         // packed_row * 8
    // packed_col * 2 bytes (B_smem column offset)
    shl.b32         %r43, %r31, 1;

    // MMA fragment addressing
    and.b32         %r100, %r6, 3;         // lane % 4
    shr.b32         %r111, %r6, 2;         // lane / 4 (0..7)
    shl.b32         %r110, %r7, 4;         // warp_id * 16

    // Column bounds check (used throughout)
    setp.lt.u32     %p2, %r32, %r0;

    // ================================================================
    // STEP 4: Load initial scales (group 0)
    // ================================================================
    setp.lt.u32     %p3, %r3, 64;
    @!%p3 bra       SKIP_SCALE_INIT;

    add.u32         %r55, %r10, %r3;       // global N col
    setp.lt.u32     %p4, %r55, %r0;
    cvt.u64.u32     %rd33, %r55;
    shl.b64         %rd33, %rd33, 1;
    add.u64         %rd34, %rd1, %rd33;    // scales_ptr + col * 2 (group 0)

    shl.b32         %r56, %r3, 1;
    add.u32         %r57, %r41, %r56;

    mov.b16         %htmp2, 0;
    @%p4 ld.global.b16 %htmp2, [%rd34];
    st.shared.b16   [%r57], %htmp2;

SKIP_SCALE_INIT:
    bar.sync        0;

    // ================================================================
    // K_LOOP: process BK=16 elements per iteration
    // ================================================================
    mov.u32         %r50, 0;               // k_offset (elements, step 16)

K_LOOP:
    setp.ge.u32     %p5, %r50, %r1;
    @%p5 bra        K_DONE;

    // ---- Load packed weights from global memory ----
    shr.b32         %r60, %r50, 3;         // k_offset / 8 = packed row base
    add.u32         %r61, %r60, %r30;      // + packed_row (0 or 1)
    cvt.u64.u32     %rd40, %r61;
    mul.lo.u64      %rd41, %rd40, %rd20;   // * row_stride (N * 4)
    add.u64         %rd42, %rd0, %rd41;    // + qweight_ptr
    add.u64         %rd42, %rd42, %rd21;   // + col offset

    mov.u32         %r62, 0;
    @%p2 ld.global.b32 %r62, [%rd42];

    // ---- Read scale for this column ----
    add.u32         %r64, %r41, %r43;     // S_smem + packed_col * 2
    ld.shared.b16   %htmp1, [%r64];
    cvt.f32.f16     %f10, %htmp1;

    // ---- Dequantize 8 nibbles -> 8 f16 values ----
    and.b32         %r70, %r62, 0xF;
    shr.b32         %r71, %r62, 4;  and.b32 %r71, %r71, 0xF;
    shr.b32         %r72, %r62, 8;  and.b32 %r72, %r72, 0xF;
    shr.b32         %r73, %r62, 12; and.b32 %r73, %r73, 0xF;
    shr.b32         %r74, %r62, 16; and.b32 %r74, %r74, 0xF;
    shr.b32         %r75, %r62, 20; and.b32 %r75, %r75, 0xF;
    shr.b32         %r76, %r62, 24; and.b32 %r76, %r76, 0xF;
    shr.b32         %r77, %r62, 28; and.b32 %r77, %r77, 0xF;

    cvt.rn.f32.u32  %f20, %r70; sub.f32 %f20, %f20, 0f40E00000; mul.f32 %f20, %f20, %f10;
    cvt.rn.f32.u32  %f21, %r71; sub.f32 %f21, %f21, 0f40E00000; mul.f32 %f21, %f21, %f10;
    cvt.rn.f32.u32  %f22, %r72; sub.f32 %f22, %f22, 0f40E00000; mul.f32 %f22, %f22, %f10;
    cvt.rn.f32.u32  %f23, %r73; sub.f32 %f23, %f23, 0f40E00000; mul.f32 %f23, %f23, %f10;
    cvt.rn.f32.u32  %f24, %r74; sub.f32 %f24, %f24, 0f40E00000; mul.f32 %f24, %f24, %f10;
    cvt.rn.f32.u32  %f25, %r75; sub.f32 %f25, %f25, 0f40E00000; mul.f32 %f25, %f25, %f10;
    cvt.rn.f32.u32  %f26, %r76; sub.f32 %f26, %f26, 0f40E00000; mul.f32 %f26, %f26, %f10;
    cvt.rn.f32.u32  %f27, %r77; sub.f32 %f27, %f27, 0f40E00000; mul.f32 %f27, %f27, %f10;

    // Store dequantized weights to B_smem as f16
    // Layout: [16][64] f16, row-major. stride = 64 * 2 = 128 bytes per row.
    // Row = packed_row * 8 + nibble_idx, Col = packed_col
    // Offset = row * 128 + packed_col * 2

    // nibble 0: row = packed_row*8
    shl.b32         %r80, %r42, 7;         // (packed_row * 8) * 128
    add.u32         %r81, %r40, %r80;
    add.u32         %r81, %r81, %r43;      // + packed_col * 2
    cvt.rn.f16.f32  %htmp0, %f20;
    st.shared.b16   [%r81], %htmp0;

    // nibble 1
    add.u32         %r82, %r81, 128;
    cvt.rn.f16.f32  %htmp0, %f21;
    st.shared.b16   [%r82], %htmp0;

    // nibble 2
    add.u32         %r82, %r82, 128;
    cvt.rn.f16.f32  %htmp0, %f22;
    st.shared.b16   [%r82], %htmp0;

    // nibble 3
    add.u32         %r82, %r82, 128;
    cvt.rn.f16.f32  %htmp0, %f23;
    st.shared.b16   [%r82], %htmp0;

    // nibble 4
    add.u32         %r82, %r82, 128;
    cvt.rn.f16.f32  %htmp0, %f24;
    st.shared.b16   [%r82], %htmp0;

    // nibble 5
    add.u32         %r82, %r82, 128;
    cvt.rn.f16.f32  %htmp0, %f25;
    st.shared.b16   [%r82], %htmp0;

    // nibble 6
    add.u32         %r82, %r82, 128;
    cvt.rn.f16.f32  %htmp0, %f26;
    st.shared.b16   [%r82], %htmp0;

    // nibble 7
    add.u32         %r82, %r82, 128;
    cvt.rn.f16.f32  %htmp0, %f27;
    st.shared.b16   [%r82], %htmp0;

    bar.sync        0;

    // ================================================================
    // Prepare A fragment (input vector from X_smem, convert to f16)
    // AND compute residual for precision compensation
    //
    // For m16n8k16 MMA, A fragment {a0, a1, a2, a3} each f16x2:
    //   a0 = {A[lane/4, (lane%4)*2], A[lane/4, (lane%4)*2+1]}
    //   a1 = {A[lane/4+8, (lane%4)*2], A[lane/4+8, (lane%4)*2+1]}
    //   a2 = {A[lane/4, (lane%4)*2+8], A[lane/4, (lane%4)*2+8+1]}
    //   a3 = {A[lane/4+8, (lane%4)*2+8], A[lane/4+8, (lane%4)*2+8+1]}
    //
    // For GEMV (broadcast): all rows same, so a0==a1, a2==a3.
    // k_col for a0: (lane%4)*2 and (lane%4)*2+1
    // k_col for a2: (lane%4)*2+8 and (lane%4)*2+8+1
    // ================================================================

    // k_col_base = (lane%4) * 2
    shl.b32         %r90, %r100, 1;        // (lane%4) * 2

    // Load f32 from X_smem at k_offset + k_col_base
    add.u32         %r91, %r50, %r90;      // global k index
    shl.b32         %r92, %r91, 2;         // * 4 bytes
    add.u32         %r93, %r20, %r92;      // X_smem addr

    // Load 2 f32 values for a0
    ld.shared.f32   %f30, [%r93];          // x[k + (lane%4)*2]
    ld.shared.f32   %f31, [%r93 + 4];      // x[k + (lane%4)*2 + 1]

    // Convert to f16
    cvt.rn.f16.f32  %htmp0, %f30;
    cvt.rn.f16.f32  %htmp1, %f31;
    mov.b32         %b0, {%htmp0, %htmp1}; // a0 = a1

    // Compute residual: r = x_f32 - cvt.f32(x_f16)
    cvt.f32.f16     %f32, %htmp0;
    cvt.f32.f16     %f33, %htmp1;
    sub.f32         %f34, %f30, %f32;      // residual[0]
    sub.f32         %f35, %f31, %f33;      // residual[1]
    cvt.rn.f16.f32  %htmp2, %f34;
    cvt.rn.f16.f32  %htmp3, %f35;
    mov.b32         %b4, {%htmp2, %htmp3}; // a0_res = a1_res

    // Same for a2 (k cols +8)
    add.u32         %r94, %r93, 32;        // +8 f32 = +32 bytes
    ld.shared.f32   %f36, [%r94];
    ld.shared.f32   %f37, [%r94 + 4];

    cvt.rn.f16.f32  %htmp0, %f36;
    cvt.rn.f16.f32  %htmp1, %f37;
    mov.b32         %b1, {%htmp0, %htmp1}; // a2 = a3

    cvt.f32.f16     %f38, %htmp0;
    cvt.f32.f16     %f39, %htmp1;
    sub.f32         %f60, %f36, %f38;
    sub.f32         %f61, %f37, %f39;
    cvt.rn.f16.f32  %htmp2, %f60;
    cvt.rn.f16.f32  %htmp3, %f61;
    mov.b32         %b5, {%htmp2, %htmp3}; // a2_res = a3_res

    // a1 = a0, a3 = a2 (GEMV: all rows same)
    mov.b32         %b2, %b0;              // a1 = a0
    mov.b32         %b3, %b1;              // a3 = a2
    mov.b32         %b6, %b4;              // a1_res
    mov.b32         %b7, %b5;              // a3_res

    // ================================================================
    // Prepare B fragment from B_smem
    // For m16n8k16 B fragment {b0, b1} each f16x2:
    //   b0 = {B[(lane%4)*2, lane/4], B[(lane%4)*2+1, lane/4]}
    //   b1 = {B[(lane%4)*2+8, lane/4], B[(lane%4)*2+8+1, lane/4]}
    // k-rows, n-col within the 8-col MMA tile
    // ================================================================

    // Warp N-col base
    add.u32         %r112, %r110, %r111;   // warp_col_base + lane/4 = n_col in tile

    // k_row = (lane%4)*2
    shl.b32         %r113, %r100, 1;

    // B_smem addr for (k_row, n_col): k_row * 128 + n_col * 2
    shl.b32         %r114, %r113, 7;       // k_row * 128
    shl.b32         %r115, %r112, 1;       // n_col * 2
    add.u32         %r116, %r40, %r114;
    add.u32         %r116, %r116, %r115;

    // Load B frag b0: B[k_row, n_col] and B[k_row+1, n_col]
    ld.shared.b16   %htmp0, [%r116];       // B[k_row, n_col]
    add.u32         %r117, %r116, 128;     // next k_row (+128 bytes)
    ld.shared.b16   %htmp1, [%r117];       // B[k_row+1, n_col]
    mov.b32         %b10, {%htmp0, %htmp1};

    // b1: k_row+8 and k_row+9
    add.u32         %r118, %r116, 1024;    // +8 rows * 128
    ld.shared.b16   %htmp0, [%r118];
    add.u32         %r119, %r118, 128;
    ld.shared.b16   %htmp1, [%r119];
    mov.b32         %b11, {%htmp0, %htmp1};

    // ---- MMA n-tile 0 (main) ----
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32
        {%f0, %f1, %f2, %f3},
        {%b0, %b2, %b1, %b3},
        {%b10, %b11},
        {%f0, %f1, %f2, %f3};

    // ---- MMA n-tile 0 (residual) ----
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32
        {%f0, %f1, %f2, %f3},
        {%b4, %b6, %b5, %b7},
        {%b10, %b11},
        {%f0, %f1, %f2, %f3};

    // ---- MMA n-tile 1 (cols +8) ----
    add.u32         %r120, %r112, 8;       // n_col + 8
    shl.b32         %r121, %r120, 1;
    add.u32         %r122, %r40, %r114;
    add.u32         %r122, %r122, %r121;

    ld.shared.b16   %htmp0, [%r122];
    add.u32         %r123, %r122, 128;
    ld.shared.b16   %htmp1, [%r123];
    mov.b32         %b12, {%htmp0, %htmp1};

    add.u32         %r124, %r122, 1024;
    ld.shared.b16   %htmp0, [%r124];
    add.u32         %r125, %r124, 128;
    ld.shared.b16   %htmp1, [%r125];
    mov.b32         %b13, {%htmp0, %htmp1};

    // Main
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32
        {%f4, %f5, %f6, %f7},
        {%b0, %b2, %b1, %b3},
        {%b12, %b13},
        {%f4, %f5, %f6, %f7};

    // Residual
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32
        {%f4, %f5, %f6, %f7},
        {%b4, %b6, %b5, %b7},
        {%b12, %b13},
        {%f4, %f5, %f6, %f7};

    bar.sync        0;

    // ---- Advance K ----
    add.u32         %r50, %r50, 16;

    // Update scale if crossing group boundary (every 128 elements)
    and.b32         %r130, %r50, 127;
    setp.ne.u32     %p7, %r130, 0;
    @%p7 bra        K_LOOP;

    // Load new scales
    setp.ge.u32     %p8, %r50, %r1;
    @%p8 bra        K_DONE;

    setp.lt.u32     %p9, %r3, 64;
    @!%p9 bra       SKIP_SCALE_UPDATE;

    shr.b32         %r131, %r50, 7;        // group = k_offset / 128
    add.u32         %r132, %r10, %r3;      // global N col
    setp.lt.u32     %p10, %r132, %r0;

    cvt.u64.u32     %rd50, %r131;
    mul.lo.u64      %rd51, %rd50, %rd22;   // group * N * 2
    add.u64         %rd52, %rd1, %rd51;
    cvt.u64.u32     %rd53, %r132;
    shl.b64         %rd53, %rd53, 1;
    add.u64         %rd54, %rd52, %rd53;

    shl.b32         %r133, %r3, 1;
    add.u32         %r134, %r41, %r133;

    mov.b16         %htmp2, 0;
    @%p10 ld.global.b16 %htmp2, [%rd54];
    st.shared.b16   [%r134], %htmp2;

SKIP_SCALE_UPDATE:
    bar.sync        0;
    bra             K_LOOP;

K_DONE:
    // ================================================================
    // EPILOGUE: Extract row 0 results and store to global output
    // ================================================================
    // MMA accumulator layout (m16n8k16):
    //   f0 = C[lane/4, (lane%4)*2], f1 = C[lane/4, (lane%4)*2+1]
    //   f2 = C[lane/4+8, (lane%4)*2], f3 = C[lane/4+8, (lane%4)*2+1]
    // For GEMV all rows same. Lanes 0-3 (lane/4==0) hold row 0.

    shr.b32         %r150, %r6, 2;         // lane / 4
    setp.ne.u32     %p12, %r150, 0;
    @%p12 bra       DONE;

    // Lanes 0-3 write 4 values each (2 n-tiles * 2 cols)
    // Global col for n-tile 0: tile_origin + warp_id*16 + (lane%4)*2
    add.u32         %r151, %r10, %r110;    // tile_origin + warp_col_base
    shl.b32         %r152, %r100, 1;       // (lane%4) * 2
    add.u32         %r153, %r151, %r152;

    // n-tile 0, col 0
    setp.lt.u32     %p13, %r153, %r0;
    @!%p13 bra      SKIP_ST0;
    cvt.u64.u32     %rd70, %r153;
    shl.b64         %rd71, %rd70, 2;
    add.u64         %rd72, %rd3, %rd71;
    st.global.f32   [%rd72], %f0;
SKIP_ST0:

    // n-tile 0, col 1
    add.u32         %r154, %r153, 1;
    setp.lt.u32     %p14, %r154, %r0;
    @!%p14 bra      SKIP_ST1;
    cvt.u64.u32     %rd73, %r154;
    shl.b64         %rd74, %rd73, 2;
    add.u64         %rd75, %rd3, %rd74;
    st.global.f32   [%rd75], %f1;
SKIP_ST1:

    // n-tile 1, col 0
    add.u32         %r155, %r153, 8;
    setp.lt.u32     %p15, %r155, %r0;
    @!%p15 bra      SKIP_ST2;
    cvt.u64.u32     %rd76, %r155;
    shl.b64         %rd77, %rd76, 2;
    add.u64         %rd78, %rd3, %rd77;
    st.global.f32   [%rd78], %f4;
SKIP_ST2:

    // n-tile 1, col 1
    add.u32         %r156, %r155, 1;
    setp.lt.u32     %p16, %r156, %r0;
    @!%p16 bra      DONE;
    cvt.u64.u32     %rd79, %r156;
    shl.b64         %rd80, %rd79, 2;
    add.u64         %rd81, %rd3, %rd80;
    st.global.f32   [%rd81], %f5;

DONE:
    ret;
}
