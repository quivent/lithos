.version 8.0
.target sm_90
.address_size 64

.visible .entry probe_predicate(
    .param .u64 param_out
)
{
    .reg .f32 %f<10>;
    .reg .u64 %rd<4>;
    .reg .pred %p<8>;

    ld.param.u64 %rd0, [param_out];

    ld.global.f32 %f0, [%rd0];
    ld.global.f32 %f1, [%rd0+4];

    // Set various predicates
    setp.gt.f32 %p0, %f0, %f1;
    setp.lt.f32 %p1, %f0, %f1;
    setp.eq.f32 %p2, %f0, %f1;
    setp.ne.f32 %p3, %f0, %f1;

    // Use predicates @P0, @P1, @P2, @P3
    mov.f32 %f2, 0f3F800000;
    mov.f32 %f3, 0f40000000;

    @%p0 add.f32 %f4, %f0, %f2;
    @%p1 add.f32 %f5, %f0, %f2;
    @%p2 add.f32 %f6, %f0, %f2;
    @%p3 add.f32 %f7, %f0, %f2;

    // Negated predicates
    @!%p0 add.f32 %f4, %f0, %f3;
    @!%p1 add.f32 %f5, %f0, %f3;

    // Store
    st.global.f32 [%rd0+8], %f4;
    st.global.f32 [%rd0+12], %f5;
    st.global.f32 [%rd0+16], %f6;
    st.global.f32 [%rd0+20], %f7;

    ret;
}
