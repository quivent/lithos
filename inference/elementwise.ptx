.version 8.0
.target sm_90
.address_size 64

.visible .entry residual_add(
    .param .u64 a,
    .param .u64 b,
    .param .u64 output
)
{
    .reg .pred %p<32>;
    .reg .b32  %r<128>;
    .reg .b64  %rd<64>;
    .reg .f32  %f<128>;

    ld.param.u64 %rd0, [a];
    ld.param.u64 %rd1, [b];
    ld.param.u64 %rd2, [output];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd0, %rd22;
    ld.global.f32 %f0, [%rd23];
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd1, %rd22;
    ld.global.f32 %f1, [%rd23];
    add.f32 %f2, %f0, %f1;
    mul.wide.u32 %rd22, %r3, 4;
    add.u64 %rd23, %rd2, %rd22;
    st.global.f32 [%rd23], %f2;

$L_exit:
    ret;
}
.visible .entry elemwise_mul(
    .param .u64 a,
