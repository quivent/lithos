// gptq_matvec_tc.ptx -- Optimized GPTQ W4A16 GEMV with tiled output + smem input
//
// Computes: output[n] = sum_k( dequant(qweight[k/8, n], k%8) * input[k] )
//   where dequant(packed, bit) = ((packed >> (bit*4)) & 0xF - 7) * scales[k/128, n]
//
// qweight layout: [K/8, N] int32 row-major
// scales layout:  [K/128, N] float16 row-major
// input layout:   [K] float32
// output layout:  [N] float32
//
// Launch: grid=(ceil(N/128), 1, 1), block=(256, 1, 1)
// Each block computes 128 output elements.
// 256 threads = 8 warps. Each warp handles 16 output columns.
// 32 threads per warp cooperatively reduce K_packed (stride 32).
// Vectorized weight loads: ld.global.v4.b32 loads 4 int32 = 4 columns at once.
// Each thread loads 4 cols per K-step, 2 loads per K-step for 8 cols total.
// Wait -- simpler: each thread does 1 ld per col. With 16 cols/warp that's
// 16 loads, but we only do K_packed/32 iterations. Let's see what's faster.
//
// Actually the fastest approach for bandwidth-bound GEMV is fewer cols per block
// but maximizing parallelism. Let's try 128 cols/block, 256 threads.
// Each warp=32 threads handles 16 cols, each thread handles 16/32=0.5 cols?
// No, that doesn't work. Each thread handles ALL 16 cols, reducing along K.
//
// Better: 256 threads, each thread handles 1 output column.
// Thread t handles output[tile_origin + t].
// Each thread reads K/8 packed int32 weights (striding 1) and the shared-memory input.
// No intra-warp reduction needed -- each thread computes one full output.
// K/8 = 640 packed words. 640 global loads per thread, 256 threads = 163840 loads.
// That's too many.
//
// Alternatively: 256 threads, 128 cols. 2 threads per output column.
// Thread t: col = t/2, half = t%2. Each half does K_packed/2 iterations.
// Then reduce via shuffle. 640/2 = 320 loads per thread.
//
// The sweet spot: enough cols to be bandwidth efficient but not so many
// that each thread does too many loads. The original had 1 col, 256 threads
// reducing K (256 threads * 1 load each = 640/256 ~= 3 loads/thread).
// We need to amortize the block launch overhead.
//
// Let's go with: 128 cols/block, 256 threads.
// 2 threads per col. Each thread processes K_packed/2 packed words.
// That's 320 packed words per thread, 320 global ld.b32, but from 128 different
// column positions (actually 1 col per pair).
//
// Wait, let me reconsider. The issue with the original is launching 12288 blocks.
// Let me try 8 cols/block, 256 threads. 32 threads per col.
// K_packed/32 = 20 loads per thread. 12288/8 = 1536 blocks. Still a lot.
//
// OK let me go with 64 cols/block, 256 threads, 4 threads per col.
// K_packed/4 = 160 loads per thread. 192 blocks. That should be fine.
//
// Actually the version that worked (8 cols/warp, 8 warps, 64 cols, 1.20ms)
// had 20 loads/thread * 8 cols = 160 loads/thread. The bottleneck is
// that these 8 loads per K-step have data dependencies (same thread, different cols).
// The loads from different cols are independent, so the GPU can pipeline them.
// The issue might be register pressure or occupancy.
//
// Let me try reducing to 4 cols per warp to halve register usage and increase occupancy.
// 4 cols/warp * 8 warps = 32 cols/block. 12288/32 = 384 blocks.

.version 8.5
.target sm_90
.address_size 64

.extern .shared .align 16 .b8 X_smem[];

.visible .entry gptq_matvec_tc(
    .param .u64 qweight_ptr,
    .param .u64 scales_ptr,
    .param .u64 input_ptr,
    .param .u64 output_ptr,
    .param .u32 param_N,
    .param .u32 param_K
)
{
    .reg .u64   %rd<50>;
    .reg .u32   %r<80>;
    .reg .f32   %f<20>;
    .reg .pred  %p<16>;
    .reg .b32   %shfl;
    .reg .b16   %htmp;

    // Dynamic shared memory: X_smem declared as extern at module scope

    // ---- Load parameters ----
    ld.param.u64    %rd0, [qweight_ptr];
    ld.param.u64    %rd1, [scales_ptr];
    ld.param.u64    %rd2, [input_ptr];
    ld.param.u64    %rd3, [output_ptr];
    ld.param.u32    %r0,  [param_N];
    ld.param.u32    %r1,  [param_K];

    mov.u32         %r3,  %tid.x;          // 0..255
    mov.u32         %r4,  %ctaid.x;        // block index (N-tile)
    and.b32         %r6,  %r3, 31;         // lane id
    shr.b32         %r7,  %r3, 5;          // warp id (0..7)

    // N-tile origin: ctaid.x * 128
    shl.b32         %r10, %r4, 7;

    setp.ge.u32     %p0, %r10, %r0;
    @%p0 bra        DONE;

    // ================================================================
    // Load input vector into shared memory (cooperative)
    // ================================================================
    mov.u32         %r20, X_smem;
    mov.u32         %r21, %r3;
LOAD_X:
    setp.ge.u32     %p1, %r21, %r1;
    @%p1 bra        LOAD_X_DONE;
    cvt.u64.u32     %rd10, %r21;
    shl.b64         %rd11, %rd10, 2;
    add.u64         %rd12, %rd2, %rd11;
    ld.global.f32   %f0, [%rd12];
    shl.b32         %r22, %r21, 2;
    add.u32         %r23, %r20, %r22;
    st.shared.f32   [%r23], %f0;
    add.u32         %r21, %r21, 256;
    bra             LOAD_X;
LOAD_X_DONE:
    bar.sync        0;

    // ================================================================
    // Each warp handles 16 output columns.
    // warp_col_base = tile_origin + warp_id * 16
    // Each thread has 16 accumulators (one per col).
    // 32 threads reduce K with stride 32.
    // ================================================================

    shl.b32         %r30, %r0, 2;          // N * 4 (qweight row stride bytes)
    cvt.u64.u32     %rd20, %r30;
    shl.b32         %r31, %r0, 1;          // N * 2 (scales row stride bytes)
    cvt.u64.u32     %rd21, %r31;
    shr.b32         %r32, %r1, 3;          // K_packed

    // Warp's global col base
    shl.b32         %r33, %r7, 4;          // warp_id * 16
    add.u32         %r34, %r10, %r33;      // tile_origin + warp_id * 16

    // Col byte offset base for qweight: r34 * 4
    shl.b32         %r35, %r34, 2;
    cvt.u64.u32     %rd22, %r35;

    // 16 accumulators
    mov.f32         %f0,  0f00000000;
    mov.f32         %f1,  0f00000000;
    mov.f32         %f2,  0f00000000;
    mov.f32         %f3,  0f00000000;
    mov.f32         %f4,  0f00000000;
    mov.f32         %f5,  0f00000000;
    mov.f32         %f6,  0f00000000;
    mov.f32         %f7,  0f00000000;
    mov.f32         %f8,  0f00000000;
    mov.f32         %f9,  0f00000000;
    mov.f32         %f10, 0f00000000;
    mov.f32         %f11, 0f00000000;
    mov.f32         %f12, 0f00000000;
    mov.f32         %f13, 0f00000000;
    mov.f32         %f14, 0f00000000;
    mov.f32         %f15, 0f00000000;

    // Scale tracking
    mov.u32         %r40, 0;               // current_group
    mov.u32         %r41, 128;             // next_group_k

    // Load initial scales
    .reg .f32 %sc<16>;
    // We'll load scales for all 16 cols. Use a loop-like pattern.
    // scale = scales_ptr + 0*N*2 + (r34+c)*2

    // Macro: load scale for col c into %sc<c>
    // For brevity, unrolled:
    .reg .u64 %srd;
    .reg .u32 %stmp;

    add.u32 %stmp, %r34, 0; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc0, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc0, %htmp;
    add.u32 %stmp, %r34, 1; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc1, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc1, %htmp;
    add.u32 %stmp, %r34, 2; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc2, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc2, %htmp;
    add.u32 %stmp, %r34, 3; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc3, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc3, %htmp;
    add.u32 %stmp, %r34, 4; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc4, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc4, %htmp;
    add.u32 %stmp, %r34, 5; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc5, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc5, %htmp;
    add.u32 %stmp, %r34, 6; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc6, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc6, %htmp;
    add.u32 %stmp, %r34, 7; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc7, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc7, %htmp;
    add.u32 %stmp, %r34, 8; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc8, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc8, %htmp;
    add.u32 %stmp, %r34, 9; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc9, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc9, %htmp;
    add.u32 %stmp, %r34, 10; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc10, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc10, %htmp;
    add.u32 %stmp, %r34, 11; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc11, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc11, %htmp;
    add.u32 %stmp, %r34, 12; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc12, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc12, %htmp;
    add.u32 %stmp, %r34, 13; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc13, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc13, %htmp;
    add.u32 %stmp, %r34, 14; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc14, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc14, %htmp;
    add.u32 %stmp, %r34, 15; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd1, %srd; mov.f32 %sc15, 0f00000000; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc15, %htmp;

    // ================================================================
    // K_LOOP
    // Each thread processes K_packed/32 packed words.
    // For each packed word: 8 nibbles * 16 cols = 128 FMAs.
    // But we only load 1 packed word per col per iteration.
    // To get 16 cols, we need 16 loads. That's expensive.
    //
    // Alternative: Process 2 packed words per iteration (inner K-unroll of 2).
    // Each packed word = 8 nibbles = 8 K-elements.
    // 2 packed words = 16 K-elements per iteration, K-stride = 32*2 = 64 K_packed.
    // But wait, we stride by 32 packed words in K_packed. So each iteration
    // covers 1 packed word = 8 K-elements. Total iterations = K_packed/32 = 20.
    // 20 iterations * 16 loads = 320 loads per thread.
    //
    // Let's use vectorized loads: ld.global.v4.b32 loads 4 consecutive int32s.
    // Since qweight is row-major [K/8, N], consecutive columns in the same row
    // are adjacent in memory. So ld.global.v4.b32 loads 4 adjacent columns.
    // 16 cols / 4 = 4 vector loads per K-step. Much better.
    // ================================================================

    .reg .u32 %qw0, %qw1, %qw2, %qw3;
    .reg .f32 %dq;
    .reg .u32 %nib;
    .reg .f32 %xi;

    mov.u32         %r50, %r6;             // k_packed = lane_id

K_LOOP:
    setp.ge.u32     %p3, %r50, %r32;
    @%p3 bra        K_REDUCE;

    // k_base = k_packed * 8
    shl.b32         %r51, %r50, 3;

    // Scale group check
    setp.lt.u32     %p4, %r51, %r41;
    @%p4 bra        SKIP_SCALE;
    shr.b32         %r40, %r51, 7;
    add.u32         %r42, %r40, 1;
    shl.b32         %r41, %r42, 7;

    // Reload all 16 scales
    cvt.u64.u32     %rd30, %r40;
    mul.lo.u64      %rd31, %rd30, %rd21;
    add.u64         %rd32, %rd1, %rd31;    // scales_ptr + group * N * 2

    add.u32 %stmp, %r34, 0; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc0, %htmp;
    add.u32 %stmp, %r34, 1; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc1, %htmp;
    add.u32 %stmp, %r34, 2; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc2, %htmp;
    add.u32 %stmp, %r34, 3; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc3, %htmp;
    add.u32 %stmp, %r34, 4; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc4, %htmp;
    add.u32 %stmp, %r34, 5; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc5, %htmp;
    add.u32 %stmp, %r34, 6; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc6, %htmp;
    add.u32 %stmp, %r34, 7; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc7, %htmp;
    add.u32 %stmp, %r34, 8; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc8, %htmp;
    add.u32 %stmp, %r34, 9; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc9, %htmp;
    add.u32 %stmp, %r34, 10; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc10, %htmp;
    add.u32 %stmp, %r34, 11; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc11, %htmp;
    add.u32 %stmp, %r34, 12; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc12, %htmp;
    add.u32 %stmp, %r34, 13; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc13, %htmp;
    add.u32 %stmp, %r34, 14; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc14, %htmp;
    add.u32 %stmp, %r34, 15; setp.lt.u32 %p2, %stmp, %r0; cvt.u64.u32 %srd, %stmp; shl.b64 %srd, %srd, 1; add.u64 %srd, %rd32, %srd; @%p2 ld.global.b16 %htmp, [%srd]; @%p2 cvt.f32.f16 %sc15, %htmp;

SKIP_SCALE:
    // Load input from smem
    shl.b32         %r52, %r51, 2;
    add.u32         %r53, %r20, %r52;
    .reg .f32 %x<8>;
    ld.shared.f32   %x0, [%r53];
    ld.shared.f32   %x1, [%r53 + 4];
    ld.shared.f32   %x2, [%r53 + 8];
    ld.shared.f32   %x3, [%r53 + 12];
    ld.shared.f32   %x4, [%r53 + 16];
    ld.shared.f32   %x5, [%r53 + 20];
    ld.shared.f32   %x6, [%r53 + 24];
    ld.shared.f32   %x7, [%r53 + 28];

    // qweight base addr for this k_packed row
    cvt.u64.u32     %rd40, %r50;
    mul.lo.u64      %rd41, %rd40, %rd20;   // k_packed * N * 4
    add.u64         %rd42, %rd0, %rd41;    // qweight_ptr + k_packed * N * 4
    add.u64         %rd42, %rd42, %rd22;   // + col_base * 4

    // Load 16 packed weights via 4 vector loads of 4 int32 each
    ld.global.b32 %qw0, [%rd42];
    ld.global.b32 %qw1, [%rd42 + 4];
    ld.global.b32 %qw2, [%rd42 + 8];
    ld.global.b32 %qw3, [%rd42 + 12];

    // Process qw0 (col 0) -- 8 nibbles
    and.b32 %nib, %qw0, 0xF;       cvt.rn.f32.u32 %dq, %nib; sub.f32 %dq, %dq, 0f41000000; mul.f32 %dq, %dq, %sc0; fma.rn.f32 %f0, %dq, %x0, %f0;
